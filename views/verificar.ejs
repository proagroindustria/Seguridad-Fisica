<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro de Asistencia — PROAGRO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800&family=Barlow:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
  <script src="/js/facial.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>
  <style>
    .cam-container {
      position: relative;
      width: 100%;
      max-width: 560px;
      margin: 0 auto;
      background: #000;
      border: 2px solid var(--border);
      overflow: hidden;
    }
    .cam-container video,
    .cam-container canvas {
      width: 100%;
      height: 380px;
      object-fit: cover;
      display: block;
    }
    .cam-container canvas {
      position: absolute;
      top: 0; left: 0;
    }
    .resultado-card {
      max-width: 560px;
      margin: 16px auto 0;
      padding: 20px 24px;
      border-radius: 2px;
      display: none;
      animation: slideUp 0.3s ease;
    }
    .resultado-card.permitido {
      display: block;
      background: var(--success-bg);
      border: 1.5px solid var(--success);
    }
    .resultado-card.denegado {
      display: block;
      background: var(--danger-bg);
      border: 1.5px solid var(--danger);
    }
    @keyframes slideUp {
      from { opacity:0; transform: translateY(10px); }
      to   { opacity:1; transform: translateY(0); }
    }

    /* ── Panel de acceso denegado con motivo ─────────── */
    @keyframes denegadoIn {
      from { opacity: 0; transform: scale(0.95); }
      to   { opacity: 1; transform: scale(1); }
    }
    #panel-denegado {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(0, 0, 0, 0.82);
      align-items: center;
      justify-content: center;
    }
    #panel-denegado.visible {
      display: flex;
    }
    .denegado-card {
      background: #fff;
      width: min(460px, 92vw);
      border-radius: 4px;
      overflow: hidden;
      animation: denegadoIn 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .denegado-header {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 22px 24px 18px;
    }
    .denegado-header.color-danger  { border-left: 5px solid #e24b4a; }
    .denegado-header.color-warning { border-left: 5px solid #ef9f27; }
    .denegado-icono {
      font-size: 36px;
      line-height: 1;
      flex-shrink: 0;
    }
    .denegado-info {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .denegado-nombre {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: #111;
      letter-spacing: 0.5px;
      margin: 0;
    }
    .denegado-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 2px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      width: fit-content;
    }
    .denegado-badge.danger  { background: #e24b4a; color: #fff; }
    .denegado-badge.warning { background: #ef9f27; color: #fff; }
    .denegado-motivo {
      padding: 14px 24px 20px;
      border-top: 1px solid #eee;
    }
    .denegado-motivo p {
      margin: 0;
      font-size: 14px;
      line-height: 1.6;
    }
    .denegado-motivo.color-danger  p { color: #7a1f1f; }
    .denegado-motivo.color-warning p { color: #5a3200; }
    .denegado-footer {
      padding: 10px 24px 16px;
      text-align: center;
    }
    .denegado-footer span {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: #aaa;
    }
  </style>
</head>
<body>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">
        <div class="logo-mark-sm">P</div>
        <div><span class="sidebar-brand">PROAGRO</span><span class="sidebar-version">v1.0.0</span></div>
      </div>
      <button class="sidebar-close" onclick="closeSidebar()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
      <div class="user-info">
        <span class="user-name"><%= user.nombre_completo %></span>
        <span class="user-role-badge role-seguridad_fisica">VIG. FÍSICA</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <p class="nav-section-label">NAVEGACIÓN</p>
      <a href="/verificar" class="nav-item active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="8" r="4"/>
          <path d="M3 20c0-4 4-7 9-7s9 3 9 7"/>
        </svg>
        <span>Registro de Asistencia</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/logout-asistencia" class="nav-item nav-logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        <span>Cerrar Sesión</span>
      </a>
    </div>
  </aside>

  <div class="main-wrapper">
    <div class="topbar">
      <div class="topbar-left">
        <button class="menu-toggle" onclick="openSidebar()"><span></span><span></span><span></span></button>
        <div class="topbar-brand">
          <div class="topbar-logo-mark">P</div>
          <span class="topbar-title">PROAGRO</span>
          <span class="topbar-sep">/</span>
          <span class="topbar-section">Registro de Asistencia</span>
        </div>
      </div>
      <div class="topbar-right">
        <div class="topbar-user">
          <div class="topbar-avatar"><%= user.nombre_completo.charAt(0).toUpperCase() %></div>
          <span class="topbar-username"><%= user.username %></span>
        </div>
      </div>
    </div>

    <div class="page-content" style="align-items:center">

      <div style="max-width:560px;width:100%;margin:0 auto">
        <p class="section-eyebrow">VIGILANCIA FÍSICA</p>
        <h1 class="section-title" style="margin-bottom:20px">Registro de Asistencia</h1>

        <div id="verif-status" style="padding:10px 16px;border:1px solid var(--border);background:var(--bg-3);font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--text-2);text-align:center;margin-bottom:12px">
          ⏳ Iniciando cámara...
        </div>

        <div class="cam-container">
          <video id="verif-video" autoplay muted playsinline></video>
          <canvas id="verif-canvas"></canvas>
        </div>

        <div style="text-align:center;font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text-3);padding:8px 0">
          El sistema detecta ENTRADA / SALIDA automáticamente
        </div>

        <button id="btn-verificar" onclick="verificarRostro()" disabled
          style="width:100%;padding:14px;background:var(--black);color:var(--accent);border:2px solid var(--accent);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;letter-spacing:2px;cursor:pointer;transition:all 0.2s;margin-top:4px">
          VERIFICAR
        </button>
        <button id="btn-qr" onclick="activarModoQR()"
          style="width:100%;padding:14px;background:transparent;color:var(--text-2);border:2px solid var(--border);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;letter-spacing:2px;cursor:pointer;transition:all 0.2s;margin-top:8px">
          📱 ESCANEAR QR
        </button>
        <div id="qr-scan-status" style="display:none;text-align:center;font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--accent);padding:8px 0">
          📱 Apunta el QR a la cámara...
        </div>

        <div id="verif-result" class="resultado-card">
          <div id="res-mov" style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:700;letter-spacing:1px;margin-bottom:8px"></div>
          <div id="res-nombre" style="font-size:16px;font-weight:500;color:var(--text);margin-bottom:4px"></div>
          <div id="res-info" style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text-3)"></div>
          <div id="res-solicitud" style="margin-top:10px;font-size:12px"></div>
        </div>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- PANEL DE ACCESO DENEGADO CON MOTIVO             -->
  <!-- ═══════════════════════════════════════════════ -->
  <div id="panel-denegado" onclick="cerrarPanelDenegado()">
    <div class="denegado-card" onclick="event.stopPropagation()">
      <div class="denegado-header color-danger" id="denegado-header">
        <div class="denegado-icono" id="denegado-icono">🚫</div>
        <div class="denegado-info">
          <p class="denegado-nombre" id="denegado-nombre">—</p>
          <span class="denegado-badge danger" id="denegado-badge">Acceso denegado</span>
        </div>
      </div>
      <div class="denegado-motivo color-danger" id="denegado-motivo">
        <p id="denegado-detalle">—</p>
      </div>
      <div class="denegado-footer">
        <span>Toca fuera para cerrar · se cierra automáticamente</span>
      </div>
    </div>
  </div>

  <script>
    function openSidebar()  { document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebarOverlay').classList.add('open'); }
    function closeSidebar() { document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarOverlay').classList.remove('open'); }

    // ═══════════════════════════════════════════════
    // PANEL DENEGADO
    // ═══════════════════════════════════════════════
    const RAZON_CONFIG = {
      VETADO:            { icono: '🚫', titulo: 'Acceso vetado',       color: 'danger'  },
      INACTIVO:          { icono: '⛔', titulo: 'Trabajador inactivo', color: 'danger'  },
      SIN_INDUCCION:     { icono: '📋', titulo: 'Sin inducción',       color: 'warning' },
      INDUCCION_VENCIDA: { icono: '⏰', titulo: 'Inducción vencida',   color: 'warning' },
      SIN_PERMISO:       { icono: '📄', titulo: 'Sin permiso vigente', color: 'warning' },
      NO_ENCONTRADO:     { icono: '❓', titulo: 'No encontrado',       color: 'danger'  },
    };

    let panelDenegadoTimer = null;

    function mostrarPanelDenegado({ nombre, razon, detalle }) {
      const cfg = RAZON_CONFIG[razon] || { icono: '⛔', titulo: 'Acceso denegado', color: 'danger' };

      document.getElementById('denegado-icono').textContent   = cfg.icono;
      document.getElementById('denegado-nombre').textContent  = nombre  || 'Trabajador';
      document.getElementById('denegado-badge').textContent   = cfg.titulo;
      document.getElementById('denegado-detalle').textContent = detalle || 'Acceso no permitido.';

      document.getElementById('denegado-header').className = 'denegado-header color-' + cfg.color;
      document.getElementById('denegado-badge').className  = 'denegado-badge ' + cfg.color;
      document.getElementById('denegado-motivo').className = 'denegado-motivo color-' + cfg.color;

      document.getElementById('panel-denegado').classList.add('visible');

      if (panelDenegadoTimer) clearTimeout(panelDenegadoTimer);
      panelDenegadoTimer = setTimeout(cerrarPanelDenegado, 7000);
    }

    function cerrarPanelDenegado() {
      document.getElementById('panel-denegado').classList.remove('visible');
      if (panelDenegadoTimer) clearTimeout(panelDenegadoTimer);
    }

    // ═══════════════════════════════════════════════
    // VERIFICACIÓN FACIAL
    // ═══════════════════════════════════════════════
    let facialModelos = null;

    async function iniciarVerificacion() {
      const statusEl = document.getElementById('verif-status');
      if (!facialModelos) facialModelos = await Facial.cargarModelos();
      const ok = await Facial.iniciarCamara('verif-video', 'verif-canvas', 'environment');
      if (!ok) {
        statusEl.style.color = 'var(--danger)';
        statusEl.style.borderColor = 'var(--danger)';
        statusEl.textContent = '❌ No se pudo acceder a la cámara';
        return;
      }
      Facial.iniciarDeteccion(
        () => {
          statusEl.style.color = 'var(--success)';
          statusEl.style.borderColor = 'var(--success)';
          statusEl.style.background = 'var(--success-bg)';
          statusEl.textContent = '✅ Rostro detectado — listo para verificar';
          const btn = document.getElementById('btn-verificar');
          btn.disabled = false;
          btn.style.background = 'var(--accent)';
          btn.style.color = 'var(--black)';
        },
        () => {
          statusEl.style.color = 'var(--danger)';
          statusEl.style.borderColor = 'var(--danger)';
          statusEl.style.background = 'var(--danger-bg)';
          statusEl.textContent = '❌ Sin rostro detectado';
          const btn = document.getElementById('btn-verificar');
          btn.disabled = true;
          btn.style.background = 'var(--black)';
          btn.style.color = 'var(--accent)';
        }
      );
    }

    async function verificarRostro() {
      const descriptor = Facial.ultimoDescriptor;
      if (!descriptor) {
        mostrarNotificacion('❌', 'Sin rostro detectado', '#dc2626');
        return;
      }
      const btn = document.getElementById('btn-verificar');
      btn.textContent = '⏳ VERIFICANDO...';
      btn.disabled = true;

      let r;
      try {
        r = await Facial.verificar(descriptor);
      } catch(e) {
        mostrarNotificacion('❌', 'Error de conexión', '#dc2626');
        btn.textContent = 'VERIFICAR';
        btn.disabled = false;
        return;
      }

      console.log('Resultado verificar:', r);

      const resultEl = document.getElementById('verif-result');
      const movEl    = document.getElementById('res-mov');
      const nombreEl = document.getElementById('res-nombre');
      const infoEl   = document.getElementById('res-info');
      const solEl    = document.getElementById('res-solicitud');

      if (r.acceso === 'permitido') {
        // ACCESO PERMITIDO
        const esEntrada = r.tipo_movimiento === 'entrada';
        const color = esEntrada ? '#16a34a' : '#dc2626';
        const icono = esEntrada ? '🟢' : '🔴';
        const mov   = esEntrada ? 'ENTRADA REGISTRADA. CUÍDATE, TU FAMILIA TE ESPERA' : 'SALIDA REGISTRADA. HASTA PRONTO';

        mostrarNotificacion(icono, mov, color, r.empleado.nombre + ' ' + r.empleado.apellido);

        resultEl.className = 'resultado-card permitido';
        resultEl.style.borderColor = color;
        movEl.style.color    = color;
        movEl.textContent    = icono + ' ' + mov;
        nombreEl.textContent = r.empleado.nombre + ' ' + r.empleado.apellido;
        infoEl.textContent   = (r.empleado.empresa||'') + (r.empleado.area ? ' · ' + r.empleado.area : '') + (r.hora ? ' · ' + r.hora : '');
        solEl.innerHTML = r.solicitud
          ? '<span style="color:#16a34a">✓ Solicitud: ' + r.solicitud.folio + ' — ' + r.solicitud.empresa + '</span>'
          : '<span style="color:#d97706">⚠️ Sin solicitud activa hoy</span>';

      } else if (r.acceso_denegado) {
        // ACCESO DENEGADO POR REGLA: vetado / inactivo / sin inducción / inducción vencida / sin permiso
        mostrarPanelDenegado({ nombre: r.nombre, razon: r.razon, detalle: r.detalle });
        resultEl.style.display = 'none';

      } else {
        // ROSTRO NO RECONOCIDO
        mostrarNotificacion('❌', r.mensaje || 'Rostro no reconocido', '#dc2626');
        resultEl.style.display = 'none';
      }

      btn.textContent = 'VERIFICAR';
      btn.disabled = false;
    }

    function mostrarNotificacion(icono, texto, color, nombre) {
      const prev = document.getElementById('notif-overlay');
      if (prev) prev.remove();

      const overlay = document.createElement('div');
      overlay.id = 'notif-overlay';
      overlay.style.cssText = `
        position: fixed; inset: 0; z-index: 9999;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        background: rgba(0,0,0,0.75);
        animation: fadeIn 0.2s ease;
        cursor: pointer;
      `;
      overlay.innerHTML = `
        <div style="
          background: #fff; border: 4px solid ${color};
          padding: 40px 60px; text-align: center;
          max-width: 420px; width: 90%;
          animation: popIn 0.3s cubic-bezier(0.16,1,0.3,1);
        ">
          <div style="font-size:72px;line-height:1;margin-bottom:16px;color:${color}">${icono}</div>
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:800;letter-spacing:2px;color:${color};margin-bottom:8px">
            ${texto}
          </div>
          ${nombre ? `<div style="font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:700;letter-spacing:1px;color:#111;margin-bottom:4px">${nombre}</div>` : ''}
          <div style="font-family:'Share Tech Mono',monospace;font-size:12px;color:#888;margin-top:16px">Toca para cerrar</div>
        </div>
      `;
      overlay.onclick = () => overlay.remove();
      document.body.appendChild(overlay);
      setTimeout(() => { if (overlay.parentNode) overlay.remove(); }, 4000);
    }

    // ═══════════════════════════════════════════════
    // ESCANER QR
    // ═══════════════════════════════════════════════
    let qrScanInterval = null;
    let modoQR = false;

    function activarModoQR() {
      modoQR = true;
      const statusEl = document.getElementById('verif-status');
      const qrStatus = document.getElementById('qr-scan-status');
      const btnVerif = document.getElementById('btn-verificar');
      const btnQR    = document.getElementById('btn-qr');

      statusEl.style.color = 'var(--accent)';
      statusEl.style.borderColor = 'var(--accent)';
      statusEl.style.background = 'var(--bg-3)';
      statusEl.textContent = '📱 Modo QR activo — apunta el código a la cámara';
      if (qrStatus) qrStatus.style.display = 'block';
      if (btnVerif) btnVerif.style.display = 'none';
      if (btnQR) { btnQR.textContent = '📷 VOLVER A ROSTRO'; btnQR.onclick = desactivarModoQR; }

      if (Facial.detectionInterval) { clearInterval(Facial.detectionInterval); Facial.detectionInterval = null; }
      const verifCanvas = document.getElementById('verif-canvas');
      if (verifCanvas) {
        verifCanvas.getContext('2d').clearRect(0, 0, verifCanvas.width, verifCanvas.height);
      }

      const video = document.getElementById('verif-video');
      let qrCanvas = document.getElementById('qr-hidden-canvas');
      if (!qrCanvas) {
        qrCanvas = document.createElement('canvas');
        qrCanvas.id = 'qr-hidden-canvas';
        qrCanvas.style.display = 'none';
        document.body.appendChild(qrCanvas);
      }
      const ctx = qrCanvas.getContext('2d', { willReadFrequently: true });

      qrScanInterval = setInterval(async () => {
        if (!video || video.readyState !== video.HAVE_ENOUGH_DATA) return;
        qrCanvas.width  = video.videoWidth;
        qrCanvas.height = video.videoHeight;
        ctx.drawImage(video, 0, 0, qrCanvas.width, qrCanvas.height);
        const imageData = ctx.getImageData(0, 0, qrCanvas.width, qrCanvas.height);
        const code = jsQR(imageData.data, imageData.width, imageData.height);
        if (code) {
          clearInterval(qrScanInterval);
          qrScanInterval = null;
          if (qrStatus) qrStatus.textContent = '⏳ QR detectado — verificando...';
          await procesarQRDetectado(code.data);
        }
      }, 200);
    }

    function desactivarModoQR() {
      modoQR = false;
      if (qrScanInterval) { clearInterval(qrScanInterval); qrScanInterval = null; }
      const btnVerif = document.getElementById('btn-verificar');
      const btnQR    = document.getElementById('btn-qr');
      const qrStatus = document.getElementById('qr-scan-status');
      if (qrStatus) qrStatus.style.display = 'none';
      if (btnVerif) btnVerif.style.display = 'block';
      if (btnQR) { btnQR.textContent = '📱 ESCANEAR QR'; btnQR.onclick = activarModoQR; }
      iniciarVerificacion();
    }

    // ─── Decodificador de QR leído con teclado español ───────────────────────
    // El lector físico (HID) usa layout US, Windows usa layout ES.
    // Resultado: { → [,  " → [,  } → *,  : → Ñ,  _ → ?
    function decodeQRFisico(str) {
      if (!str) return str;
      try { JSON.parse(str); return str; } catch(e) {} // ya es JSON válido

      if (!str.startsWith('[')) return str; // formato desconocido, pasar tal cual

      try {
        let s = str.slice(1); // quitar [ inicial  (era {)
        if (s.endsWith('*')) s = s.slice(0, -1); // quitar * final (era })

        const obj = {};
        for (let parte of s.split(',')) {
          if (parte.startsWith('[')) parte = parte.slice(1); // quitar " inicial de la clave

          const sep = parte.indexOf('[Ñ'); // separador clave:valor (era :")
          if (sep === -1) continue;

          const clave = parte.slice(0, sep).replace(/\?/g, '_'); // ? era _
          let val     = parte.slice(sep + 2); // después del [Ñ

          if (val.startsWith('[')) {
            // Valor string
            val = val.slice(1);
            if (val.endsWith('[')) val = val.slice(0, -1);
            obj[clave] = val;
          } else {
            // null / true / false / número
            const v = val.replace(/\[$/, '');
            obj[clave] = v === 'null'  ? null
                       : v === 'true'  ? true
                       : v === 'false' ? false
                       : v !== '' && !isNaN(v) ? Number(v)
                       : v;
          }
        }

        if (!Object.keys(obj).length) return str;
        console.log('[QR físico decodificado]', obj);
        return JSON.stringify(obj);
      } catch(e) {
        return str; // si falla, devolver original
      }
    }

    async function procesarQRDetectado(data) {
      const decoded = decodeQRFisico(data); // normalizar antes de enviar
      const qrStatus = document.getElementById('qr-scan-status');
      try {
        const r = await Facial.verificarQR(decoded);
        console.log('Resultado QR:', r);

        const resultEl = document.getElementById('verif-result');
        const movEl    = document.getElementById('res-mov');
        const nombreEl = document.getElementById('res-nombre');
        const infoEl   = document.getElementById('res-info');
        const solEl    = document.getElementById('res-solicitud');

        if (r.acceso === 'permitido') {
          // ACCESO PERMITIDO QR
          const esEntrada = r.tipo_movimiento === 'entrada';
          const color = esEntrada ? '#16a34a' : '#dc2626';
          const icono = esEntrada ? '🟢' : '🔴';
          const mov   = esEntrada ? 'ENTRADA REGISTRADA. CUÍDATE, TU FAMILIA TE ESPERA' : 'SALIDA REGISTRADA. HASTA PRONTO';

          mostrarNotificacion(icono, mov, color, r.empleado.nombre + ' ' + r.empleado.apellido);

          resultEl.className = 'resultado-card permitido';
          resultEl.style.borderColor = color;
          movEl.style.color    = color;
          movEl.textContent    = icono + ' ' + mov;
          nombreEl.textContent = r.empleado.nombre + ' ' + r.empleado.apellido;
          infoEl.textContent   = (r.empleado.empresa||'') + (r.empleado.area ? ' · ' + r.empleado.area : '') + (r.hora ? ' · ' + r.hora : '');
          solEl.innerHTML = r.solicitud
            ? '<span style="color:#16a34a">✓ Solicitud: ' + r.solicitud.folio + '</span>'
            : '<span style="color:#d97706">⚠️ Sin solicitud activa hoy</span>';

        } else if (r.acceso_denegado) {
          // ACCESO DENEGADO POR REGLA QR
          mostrarPanelDenegado({ nombre: r.nombre, razon: r.razon, detalle: r.detalle });
          resultEl.style.display = 'none';

        } else {
          // QR no reconocido / error
          mostrarNotificacion('❌', r.mensaje || 'Acceso denegado', '#dc2626');
          resultEl.style.display = 'none';
        }

        if (qrStatus) qrStatus.style.display = 'none';
        const delay = r.acceso_denegado ? 7500 : 4000;
        setTimeout(() => {
          if (modoQR) {
            if (qrStatus) { qrStatus.style.display = 'block'; qrStatus.textContent = '📱 Apunta el QR a la cámara...'; }
            activarModoQR();
          }
        }, delay);

      } catch(e) {
        console.error('Error QR:', e);
        mostrarNotificacion('❌', 'Error al verificar QR', '#dc2626');
        setTimeout(() => { if (modoQR) activarModoQR(); }, 3000);
      }
    }

    iniciarVerificacion();

    // ═══════════════════════════════════════════════
    // LECTOR QR FÍSICO (HID / USB — emula teclado)
    // Los lectores físicos "teclean" los datos del QR
    // muy rápido y terminan con Enter.
    // ═══════════════════════════════════════════════
    (function () {
      let buf = '';
      let resetTimer = null;

      function limpiarBuffer() {
        buf = '';
        if (resetTimer) { clearTimeout(resetTimer); resetTimer = null; }
      }

      document.addEventListener('keydown', function (e) {
        // Si el foco está en un control de formulario, no interferir
        const tag = document.activeElement && document.activeElement.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;

        // Reiniciar el temporizador de inactividad (300 ms)
        if (resetTimer) clearTimeout(resetTimer);
        resetTimer = setTimeout(limpiarBuffer, 300);

        if (e.key === 'Enter') {
          const data = buf.trim();
          limpiarBuffer();
          // Mínimo razonable para descartar pulsaciones sueltas de Enter
          if (data.length >= 8) {
            console.log('[Lector QR físico] datos recibidos:', data);
            const statusEl = document.getElementById('verif-status');
            if (statusEl) {
              statusEl.textContent = '⏳ QR físico detectado — verificando...';
              statusEl.style.color = 'var(--accent)';
              statusEl.style.borderColor = 'var(--accent)';
              statusEl.style.background = 'var(--bg-3)';
              statusEl.style.display = 'block';
            }
            procesarQRDetectado(data);
          }
          return;
        }

        // Acumular caracteres imprimibles
        if (e.key.length === 1) {
          buf += e.key;
        }
      });
    })();
  </script>
</body>
</html>
