        const imssRetry = document.getElementById('enrol-imss-retry'); if(imssRetry) imssRetry.style.display='none';

        const imssLabel = document.getElementById('enrol-imss-label'); if(imssLabel) imssLabel.textContent = 'Arrastra o haz clic para subir vigencia IMSS';
        const imssDrop = document.getElementById('enrol-imss-drop'); if(imssDrop) imssDrop.style.borderColor = '#3b82f6';
        const imssInput = document.getElementById('enrol-imss-input'); if(imssInput) imssInput.value = '';
        document.getElementById('enrol-imss-input').click();
