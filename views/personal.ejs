    async function abrirFacialEnrolar() {
      document.getElementById('modalEnrolar').classList.add('open');
      document.body.style.overflow = 'hidden';
      facialDescriptorEnrol = null;
      enrolDuplicado = false;
clearTimeout(_duplicadoTimeout);
      enrolCredFile = null; enrolImssFile = null;
      enrolCredProcesado = false; enrolImssProcesado = false;
      enrolCredData = null; enrolImssData = null;

      ['enrol-nombre_completo','enrol-documento','enrol-nss','enrol-area','enrol-cargo'].forEach(id => {
        const el = document.getElementById(id); if (el) el.value = '';
      });
      const credProc = document.getElementById('enrol-cred-proceso'); if(credProc) credProc.style.display='none';
      const credRetry = document.getElementById('enrol-cred-retry'); if(credRetry) credRetry.style.display='none';
      const credClear = document.getElementById('enrol-cred-clear'); if(credClear) credClear.style.display='none';
      const credLabel = document.getElementById('enrol-cred-label'); if(credLabel) credLabel.textContent = 'Arrastra o haz clic para subir credencial';
      const credDrop = document.getElementById('enrol-cred-drop'); if(credDrop) credDrop.style.borderColor = 'var(--border)';
      const credInput = document.getElementById('enrol-cred-input'); if(credInput) credInput.value = '';
      const saveStatus = document.getElementById('enrol-save-status'); if(saveStatus) saveStatus.style.display = 'none';
      ['warn-foto','warn-cred'].forEach(id => { const el = document.getElementById(id); if(el) el.style.display='flex'; });
      const imssWarnEl = document.getElementById('warn-imss'); if(imssWarnEl) imssWarnEl.style.display='none';

      if (window._userRol === 'contratista' && window._userEmpresa) {
        document.getElementById('enrol-empresa').value = window._userEmpresa;
      }

      const statusEl = document.getElementById('enrol-status');
      const capEl    = document.getElementById('enrol-cap-status');
      statusEl.className = 'facial-status'; statusEl.textContent = '⏳ Iniciando cámara...';
      capEl.className = 'facial-status error'; capEl.textContent = '❌ Rostro no capturado';
      document.getElementById('btn-enrol-capturar').disabled = true;
      document.getElementById('btn-enrol-guardar').disabled  = true;

      if (!facialModelos) { facialModelos = await Facial.cargarModelos(); }
      const esCelular = ('ontouchstart' in window || navigator.maxTouchPoints > 0);
      document.getElementById('btn-flip-cam').style.display = esCelular ? 'flex' : 'none';
      window._enrolFacingMode = esCelular ? 'environment' : 'user';
      const ok = await Facial.iniciarCamara('enrol-video', 'enrol-canvas', window._enrolFacingMode);
      if (!ok) { statusEl.className = 'facial-status error'; statusEl.textContent = '❌ No se pudo acceder a la cámara'; return; }
      iniciarDeteccionEnrol();
    }

    function iniciarDeteccionEnrol() {
      const statusEl = document.getElementById('enrol-status');
      Facial.iniciarDeteccion(
        () => { statusEl.className = 'facial-status ok'; statusEl.textContent = '✅ Rostro detectado'; document.getElementById('btn-enrol-capturar').disabled = false; },
        () => { statusEl.className = 'facial-status error'; statusEl.textContent = '❌ Sin rostro detectado'; document.getElementById('btn-enrol-capturar').disabled = true; }
      );
    }

    async function flipCamaraEnrol() {
      window._enrolFacingMode = (window._enrolFacingMode === 'user') ? 'environment' : 'user';
      Facial.detenerCamara();
      document.getElementById('btn-enrol-capturar').disabled = true;
      const statusEl = document.getElementById('enrol-status');
      statusEl.className = 'facial-status'; statusEl.textContent = '⏳ Cambiando cámara...';
      const ok = await Facial.iniciarCamara('enrol-video', 'enrol-canvas', window._enrolFacingMode);
      if (!ok) { statusEl.className = 'facial-status error'; statusEl.textContent = '❌ No se pudo acceder a la cámara'; return; }
      iniciarDeteccionEnrol();
    }

    function cerrarFacialEnrolar() {
      enrolCredFile = null; enrolImssFile = null;
      enrolCredProcesado = false; enrolImssProcesado = false;
      enrolCredData = null; enrolImssData = null;
      const cc = document.getElementById('enrol-cred-clear'); if (cc) cc.style.display = 'none';
      facialDescriptorEnrol = null;
      const chk = document.getElementById('chk-aviso-privacidad'); if (chk) chk.checked = false;
      Facial.detenerCamara();
      document.getElementById('modalEnrolar').classList.remove('open');
      document.body.style.overflow = '';
      cargarPersonal();
    }

    async function capturarRostroEnrol() {
      const capEl = document.getElementById('enrol-cap-status');
      capEl.className = 'facial-status'; capEl.textContent = '⏳ Capturando...';
      const descriptor = Facial.ultimoDescriptor || await Facial.obtenerDescriptor();
      if (descriptor) {
        facialDescriptorEnrol = descriptor;
        capEl.className = 'facial-status ok'; capEl.textContent = `✅ Rostro capturado (${descriptor.length} valores)`;
        const wf = document.getElementById('warn-foto'); if(wf) wf.style.display='none';
        verificarBotonGuardar();
      } else {
        capEl.className = 'facial-status error'; capEl.textContent = '❌ No se detectó rostro — intenta de nuevo';
      }
    }




    async function verificarDuplicado() {
  const nss     = document.getElementById('enrol-nss')?.value?.trim() || '';
  const empresa = document.getElementById('enrol-empresa')?.value?.trim() || '';

  if (!nss) {
    enrolDuplicado = false;
    verificarBotonGuardar();
    return;
  }

  try {
    const res = await fetch('/facial/verificar-duplicado', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nss, empresa })
    });
    const data = await res.json();
    const procesoEl = document.getElementById('enrol-cred-proceso');

    if (data.duplicado) {
      enrolDuplicado = true;
      if (procesoEl) {
        procesoEl.style.display = 'block';
        procesoEl.style.color = 'var(--danger)';
        procesoEl.style.borderColor = 'var(--danger)';
        procesoEl.innerHTML = `⚠️ ${data.mensaje}`;
      }
     } else {
  enrolDuplicado = false;
  if (procesoEl) {
    const txt = procesoEl.innerHTML || '';
    if (txt.includes('⚠️')) {  // limpia cualquier advertencia de duplicado
      procesoEl.style.display = 'none';
      procesoEl.innerHTML = '';
    }
  }
}
  } catch(e) {
    console.warn('No se pudo verificar duplicado:', e);
    enrolDuplicado = false;
  }

  verificarBotonGuardar();
}

function verificarDuplicadoDebounced() {
  clearTimeout(_duplicadoTimeout);
  _duplicadoTimeout = setTimeout(verificarDuplicado, 600);
}


function verificarDuplicadoDebounced() {
  clearTimeout(_duplicadoTimeout);
  _duplicadoTimeout = setTimeout(verificarDuplicado, 600);
}




   function verificarBotonGuardar() {
  const tieneFoto = facialDescriptorEnrol !== null;
  const tieneCred = enrolCredProcesado;
  const fotoWarn = document.getElementById('warn-foto');
  const credWarn = document.getElementById('warn-cred');
  if (fotoWarn) fotoWarn.style.display = tieneFoto ? 'none' : 'flex';
  if (credWarn) credWarn.style.display = (enrolCredFile || tieneCred) ? 'none' : 'flex';

  const tieneNombre  = !!(document.getElementById('enrol-nombre_completo')?.value?.trim());
  const aceptoAviso  = !!(document.getElementById('chk-aviso-privacidad')?.checked);
  const btn = document.getElementById('btn-enrol-guardar');
  if (!btn) return;
  const listo = tieneFoto && tieneCred && tieneNombre && aceptoAviso && !enrolDuplicado;

  btn.disabled = !listo;
  btn.textContent = 'REGISTRAR PERSONAL';
  btn.style.opacity = '1';
  btn.style.background = listo ? 'var(--success)' : 'var(--text-3)';
  btn.style.color = listo ? '#fff' : '#999';
  btn.style.cursor = listo ? 'pointer' : 'not-allowed';
  btn.style.pointerEvents = listo ? 'auto' : 'none';
}



    
    async function fileToBase64(file) {
      return new Promise((res, rej) => {
        const r = new FileReader();
        r.onload  = () => res(r.result.split(',')[1]);
        r.onerror = rej;
        r.readAsDataURL(file);
      });
    }





    async function comprimirImagenFrontend(file) {
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        // Máximo 1000px en cualquier dimensión
        let w = img.width, h = img.height;
        const MAX = 1000;
        if (w > MAX || h > MAX) {
          if (w > h) { h = Math.round(h * MAX / w); w = MAX; }
          else       { w = Math.round(w * MAX / h); h = MAX; }
        }
        canvas.width = w; canvas.height = h;
        canvas.getContext('2d').drawImage(img, 0, 0, w, h);
        // Calidad 0.7 — buen balance para documentos
        resolve(canvas.toDataURL('image/jpeg', 0.7).split(',')[1]);
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  });
}

    function enrolArchivoSeleccionado(input, tipo) {
      const file = input.files[0];
      if (!file) return;
      if (file.size > 10 * 1024 * 1024) { alert('Archivo demasiado grande (máx 10 MB)'); return; }
      if (tipo === 'cred') {
        enrolCredFile = file; enrolCredProcesado = false; enrolCredData = null;
        document.getElementById('enrol-cred-label').textContent = '⏳ ' + file.name;
        const cc = document.getElementById('enrol-cred-clear'); if (cc) cc.style.display = 'inline-block';
      } else {
        enrolImssFile = file; enrolImssProcesado = false; enrolImssData = null;
        document.getElementById('enrol-imss-label').textContent = '⏳ ' + file.name;
      }
      verificarBotonGuardar();
      procesarDocEnrol(file, tipo);
    }

    function enrolDropFile(event, tipo) {
      event.preventDefault();
      const file = event.dataTransfer.files[0];
      if (!file) return;
      const input = document.getElementById(`enrol-${tipo}-input`);
      const dt = new DataTransfer();
      dt.items.add(file);
      input.files = dt.files;
      enrolArchivoSeleccionado(input, tipo);
    }

