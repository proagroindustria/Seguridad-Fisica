<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Personal — PROAGRO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800&family=Barlow:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

  <!-- SIDEBAR -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">
        <div class="logo-mark-sm">P</div>
        <div>
          <span class="sidebar-brand">PROAGRO</span>
          <span class="sidebar-version">v1.0.0</span>
        </div>
      </div>
      <button class="sidebar-close" onclick="closeSidebar()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
      <div class="user-info">
        <span class="user-name"><%= user.nombre_completo %></span>
        <span class="user-role-badge role-<%= user.rol %>">
          <%= user.rol === 'area' ? 'ÁREA' : user.rol === 'seguridad_fisica' ? 'VIG. FÍSICA' : 'CONTRATISTA' %>
        </span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <p class="nav-section-label">NAVEGACIÓN</p>
      <a href="/dashboard" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14,2 14,8 20,8"/>
        </svg>
        <span>Solicitudes</span>
      </a>
      <% if (user.rol === 'contratista') { %>
      <a href="/personal" class="nav-item active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span>Mi Personal</span>
      </a>
      <% } %>
      <% if (user.rol === 'seguridad_fisica') { %>
      <a href="/personal" class="nav-item active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span>Trabajadores Contratistas</span>
      </a>
      <a href="/historial" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/>
        </svg>
        <span>Registro de Incidencias</span>
      </a>
      <% } %>
    </nav>
    <div class="sidebar-footer">
      <a href="/logout" class="nav-item nav-logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16,17 21,12 16,7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        <span>Cerrar Sesión</span>
      </a>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="main-wrapper">
    <div class="topbar">
      <div class="topbar-left">
        <button class="menu-toggle" onclick="openSidebar()">
          <span></span><span></span><span></span>
        </button>
        <div class="topbar-brand">
          <div class="topbar-logo-mark">P</div>
          <span class="topbar-title">PROAGRO</span>
          <span class="topbar-sep">/</span>
          <span class="topbar-section"><%= user.rol === 'contratista' ? 'Mi Personal' : 'Trabajadores Contratistas' %></span>
        </div>
      </div>
      <div class="topbar-right">
        <% if (user.rol === 'seguridad_fisica') { %>
        <div style="position:relative" id="notifWrapper">
          <button onclick="toggleNotificaciones()" style="background:none;border:none;cursor:pointer;color:var(--text);position:relative;padding:6px;display:flex;align-items:center">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="width:22px;height:22px">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            <span id="notifBadge" style="display:none;position:absolute;top:0;right:0;background:#ef4444;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;min-width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;padding:0 3px">0</span>
          </button>
          <div id="notifPanel" style="display:none;position:absolute;right:0;top:calc(100% + 8px);width:340px;background:var(--bg-2);border:1px solid var(--border);box-shadow:0 8px 24px rgba(0,0,0,0.3);z-index:999;max-height:400px;overflow-y:auto">
            <div style="padding:14px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
              <span style="font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;color:var(--accent)">NOTIFICACIONES</span>
              <span id="notifTotal" style="font-size:11px;color:var(--text-3);font-family:'Share Tech Mono',monospace"></span>
            </div>
            <div id="notifLista"><div style="padding:20px;text-align:center;color:var(--text-3);font-size:13px">Cargando...</div></div>
          </div>
        </div>
        <% } %>
        <div class="topbar-user">
          <div class="topbar-avatar"><%= user.nombre_completo.charAt(0).toUpperCase() %></div>
          <span class="topbar-username"><%= user.username %></span>
        </div>
      </div>
    </div>

    <div class="page-content">
      <!-- HEADER -->
      <div class="section-header">
        <div>
          <p class="section-eyebrow"><%= user.rol === 'contratista' ? user.nombre_completo.toUpperCase() : 'VIGILANCIA FÍSICA' %></p>
          <h1 class="section-title"><%= user.rol === 'contratista' ? 'Mi Personal' : 'Trabajadores Contratistas' %></h1>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <div id="statsBar" style="display:flex;gap:10px"></div>
          <% if (user.rol === 'contratista') { %>
          <button onclick="abrirModalEnrolar()" style="
            display:flex;align-items:center;gap:8px;
            padding:10px 18px;
            background:var(--accent);
            color:#000;
            border:none;
            font-family:'Barlow Condensed',sans-serif;
            font-weight:700;
            font-size:13px;
            letter-spacing:1px;
            cursor:pointer;
          ">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:15px;height:15px">
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            AGREGAR TRABAJADOR
          </button>
          <% } %>
        </div>
      </div>

      <!-- TOOLBAR -->
      <div class="filter-bar">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" id="searchPersonal" placeholder="Buscar..." oninput="filtrarPersonal()">
        </div>
        <% if (user.rol === 'seguridad_fisica') { %>
        <select id="filtroEmpresa" onchange="filtrarPersonal()"
          style="padding:9px 14px;background:var(--bg-2);border:1px solid var(--border);color:var(--text);font-family:'Barlow',sans-serif;font-size:13px">
          <option value="">Todas las empresas</option>
        </select>
        <% } %>
        <select id="filtroEstatus" onchange="filtrarPersonal()"
          style="padding:9px 14px;background:var(--bg-2);border:1px solid var(--border);color:var(--text);font-family:'Barlow',sans-serif;font-size:13px">
          <option value="">Todos los estatus</option>
          <option value="no_activo">No Activo</option>
          <option value="activo">Activo</option>
          <option value="vetado">Vetado</option>
        </select>
        <div style="margin-left:auto;font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--text-3)" id="totalPersonal"></div>
      </div>

      <!-- TABLA -->
      <div class="table-container">
        <div id="personalLoading" class="table-loading">
          <div class="loading-spinner"></div>
          <span>Cargando personal...</span>
        </div>
        <table class="data-table" id="personalTable" style="display:none">
          <thead>
            <tr>
              <th>#</th>
              <th>NOMBRE</th>
              <% if (user.rol === 'seguridad_fisica') { %><th>EMPRESA</th><% } %>
              <th>NO. EMPLEADO</th>
              <th>NSS</th>
              <th>ÁREA</th>
              <th>ESTATUS</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="personalTbody"></tbody>
        </table>
        <div id="personalEmpty" style="display:none;padding:60px;text-align:center;color:var(--text-3)">No se encontraron trabajadores.</div>
      </div>
    </div>
  </div>

  <!-- MODAL DETALLE TRABAJADOR -->
  <div class="modal-overlay" id="modalTrabajador">
    <div class="modal-box" style="max-width:720px;max-height:90vh;display:flex;flex-direction:column">
      <div class="modal-header">
        <div>
          <p class="modal-eyebrow">TRABAJADOR</p>
          <h2 class="modal-title" id="trabNombre">—</h2>
        </div>
        <button class="modal-close" onclick="cerrarModalTrabajador()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div style="flex:1;overflow-y:auto;padding:20px 28px 28px" id="trabBody">Cargando...</div>
    </div>
  </div>



  <!-- MODAL: ENROLAR PERSONA — debe estar en el DOM ANTES que los scripts -->
  <div class="modal-facial" id="modalEnrolar">
    <div class="facial-box" style="width:580px;max-height:95vh;overflow-y:auto">
      <div class="facial-header">
        <h3>➕ Registrar Personal</h3>
        <button class="modal-close" onclick="cerrarFacialEnrolar()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px;height:18px"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="facial-body">
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--accent);margin-bottom:8px">PASO 1 — CAPTURA DE ROSTRO</div>
        <div id="enrol-status" class="facial-status">⏳ Iniciando cámara...</div>
        <div class="facial-cam-wrap" style="position:relative">
          <video id="enrol-video" autoplay muted playsinline></video>
          <canvas id="enrol-canvas"></canvas>
          <button id="btn-flip-cam" onclick="flipCamaraEnrol()" title="Cambiar cámara"
            style="position:absolute;top:8px;right:8px;background:rgba(0,0,0,0.5);border:none;border-radius:50%;width:36px;height:36px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;color:#fff;z-index:10">
            &#x1F501;
          </button>
        </div>
        <div id="enrol-cap-status" class="facial-status error">❌ Rostro no capturado</div>
        <div style="display:flex;justify-content:center;margin-bottom:8px">
          <button class="btn-facial" id="btn-enrol-capturar" onclick="capturarRostroEnrol()" disabled>CAPTURAR ROSTRO</button>
        </div>
        <div id="warn-foto" style="display:flex;align-items:center;gap:8px;background:#fef3c7;border:1px solid #f59e0b;padding:8px 12px;margin-bottom:12px;font-size:12px;color:#92400e">
          ⚠ Debes capturar el rostro antes de continuar
        </div>

        <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--accent);margin-bottom:8px;border-top:1px solid var(--border);padding-top:14px">PASO 2 — DOCUMENTOS OBLIGATORIOS</div>

        <div style="margin-bottom:4px">
          <div style="font-size:11px;color:var(--text-3);margin-bottom:6px;font-family:'Barlow Condensed',sans-serif;letter-spacing:0.5px">
            CREDENCIAL (INE / PASAPORTE / LICENCIA) <span style="color:var(--danger)">*</span>
          </div>
          <div id="enrol-cred-drop" onclick="if(!enrolCredFile)document.getElementById('enrol-cred-input').click()"
            style="border:2px dashed var(--border);padding:16px;text-align:center;cursor:pointer;transition:all 0.2s"
            ondragover="event.preventDefault();this.style.borderColor='var(--accent)'"
            ondragleave="this.style.borderColor='var(--border)'"
            ondrop="enrolDropFile(event,'cred')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:24px;height:24px;margin:0 auto 4px;display:block;color:var(--text-3)">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17,8 12,3 7,8"/><line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <span id="enrol-cred-label" style="font-size:12px;color:var(--text-3)">Arrastra o haz clic para subir un documento</span>
            <input type="file" id="enrol-cred-input" accept=".jpg,.jpeg,.png,.webp,.pdf" style="display:none" onchange="enrolArchivoSeleccionado(this,'cred')">
          </div>
          <div id="enrol-cred-proceso" style="display:none;margin-top:6px;padding:10px 14px;border:1px solid var(--border);font-family:'Share Tech Mono',monospace;font-size:12px"></div>
          <button id="enrol-cred-retry" onclick="enrolReintentarDoc('cred')" style="display:none;margin-top:6px;padding:6px 14px;background:transparent;border:1px solid var(--warning);color:var(--warning);font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:1px;cursor:pointer">↺ REINTENTAR DOCUMENTO</button>
          <button id="enrol-cred-clear" onclick="enrolLimpiarDoc('cred')" style="display:none;margin-top:6px;margin-left:6px;padding:6px 14px;background:transparent;border:1px solid var(--danger);color:var(--danger);font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:1px;cursor:pointer">✕ QUITAR</button>
        </div>
        <div id="warn-cred" style="display:flex;align-items:center;gap:8px;background:#fef3c7;border:1px solid #f59e0b;padding:8px 12px;margin-bottom:8px;font-size:12px;color:#92400e">
          ⚠ El documento es obligatorio
        </div>

        <!-- PASO 3: DATOS -->
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--accent);margin-bottom:8px;border-top:1px solid var(--border);padding-top:14px">PASO 3 — DATOS DEL TRABAJADOR</div>
        <div class="facial-form-grid">
          <div class="facial-field" style="grid-column:1/-1"><label>Nombre completo * <span style="color:var(--text-3);font-weight:400;font-size:10px">— se llena automáticamente desde el documento</span></label><input type="text" id="enrol-nombre_completo" placeholder="Nombre(s) y Apellidos" oninput="verificarBotonGuardar(); verificarDuplicadoDebounced()"></div>
          <div class="facial-field"><label>No. Empleado</label><input type="text" id="enrol-documento" placeholder="Número de empleado"></div>
          <div class="facial-field"><label>NSS</label><input type="text" id="enrol-nss" placeholder="NSS" oninput="verificarDuplicadoDebounced()"></div>
          <input type="hidden" id="enrol-empresa" value="">
          <div class="facial-field"><label>Área</label><input type="text" id="enrol-area" placeholder="Área"></div>
          <div class="facial-field"><label>Cargo</label><input type="text" id="enrol-cargo" placeholder="Cargo"></div>
        </div>

        <div id="enrol-save-status" style="display:none;margin-bottom:12px;font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--accent);text-align:center"></div>


        <div id="warn-datos" style="display:none;align-items:center;gap:8px;background:#fee2e2;border:1px solid #ef4444;padding:8px 12px;margin-bottom:8px;font-size:12px;color:#991b1b"></div>

        <!-- AVISO DE PRIVACIDAD — aceptación obligatoria (LFPDPPP) -->
        <div style="border:1px solid var(--border);border-radius:6px;padding:12px 14px;margin-bottom:14px;background:var(--bg-2,#f8f9fa)">
          <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;font-size:12px;color:var(--text-2);line-height:1.5">
            <input type="checkbox" id="chk-aviso-privacidad" onchange="verificarBotonGuardar()"
              style="margin-top:2px;accent-color:var(--accent);width:15px;height:15px;flex-shrink:0">
            <span>
              He leído y acepto el
              <a href="https://www.proagroindustria.com/aviso-de-privacidad/" target="_blank" rel="noopener"
                style="color:var(--accent);font-weight:600;text-decoration:underline">Aviso de Privacidad</a>
              de <strong>Pro-Agroindustria</strong>. 
            </span>
          </label>
        </div>

        <div style="display:flex;gap:10px;justify-content:center">
          <div id="enrol-pendiente-id" style="display:none"></div>
          <button class="btn-aprobar" id="btn-enrol-guardar" onclick="guardarEnrolamiento()" disabled
            style="opacity:0.4;cursor:not-allowed;pointer-events:none;">REGISTRAR PERSONAL</button>
          <button class="btn-secondary" onclick="cerrarFacialEnrolar()">Cancelar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- SCRIPTS — van después del HTML -->
  <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script>pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';</script>
  <script src="/js/facial.js"></script>
  <script src="/js/documentos.js"></script>

  <script>
    const ROL = '<%= user.rol %>';
    window._userRol = '<%= user.rol %>';
    window._userEmpresa = '<%= user.nombre_completo %>';

    let allPersonal = [];
    let currentEmpleadoId = null;

    // Variables enrolamiento
    let facialDescriptorEnrol = null;
    let facialModelos = false;
    let enrolCredFile = null;
    let enrolImssFile = null;
    let enrolCredProcesado = false;
    let enrolImssProcesado = false;
    let enrolCredData = null;
    let enrolImssData = null;
    let enrolDuplicado = false;
    let _duplicadoTimeout = null;

    function openSidebar()  { document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebarOverlay').classList.add('open'); }
    function closeSidebar() { document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarOverlay').classList.remove('open'); }

    // ===================== TABLA PERSONAL =====================
    async function cargarPersonal() {
      try {
        const url = ROL === 'contratista' ? '/facial/mi-personal' : '/facial/todo-personal';
        const r = await fetch(url);
        const d = await r.json();
        if (!d.success) throw new Error(d.error);
        allPersonal = d.data;

        if (ROL === 'seguridad_fisica') {
          const empresas = [...new Set(d.data.map(e => e.empresa).filter(Boolean))].sort();
          const sel = document.getElementById('filtroEmpresa');
          empresas.forEach(emp => {
            const opt = document.createElement('option');
            opt.value = emp; opt.textContent = emp;
            sel.appendChild(opt);
          });
        }

        const total    = d.data.length;
        const activos  = d.data.filter(e => e.estatus === 'activo').length;
        const noActivo = d.data.filter(e => e.estatus === 'no_activo').length;
        const vetados  = d.data.filter(e => e.estatus === 'vetado').length;
        document.getElementById('statsBar').innerHTML = `
          <div class="stat-chip"><span class="stat-num">${total}</span><span class="stat-label">TOTAL</span></div>
          <div class="stat-chip stat-aprobado"><span class="stat-num">${activos}</span><span class="stat-label">ACTIVOS</span></div>
          <div class="stat-chip stat-pendiente"><span class="stat-num">${noActivo}</span><span class="stat-label">PENDIENTES</span></div>
          ${vetados > 0 ? `<div class="stat-chip"><span class="stat-num" style="color:var(--danger)">${vetados}</span><span class="stat-label">VETADOS</span></div>` : ''}
        `;

        filtrarPersonal();
        document.getElementById('personalLoading').style.display = 'none';
        document.getElementById('personalTable').style.display = 'table';
      } catch(e) {
        document.getElementById('personalLoading').innerHTML = '<span style="color:var(--danger)">Error: ' + e.message + '</span>';
      }
    }

    function filtrarPersonal() {
      const busq    = document.getElementById('searchPersonal').value.toLowerCase();
      const empresa = ROL === 'seguridad_fisica' ? document.getElementById('filtroEmpresa').value : '';
      const estatus = document.getElementById('filtroEstatus').value;

      const filtrados = allPersonal.filter(e => {
        const nombre = ((e.nombre||'') + ' ' + (e.apellido||'')).toLowerCase();
        const matchBusq    = !busq || nombre.includes(busq) || (e.documento_identidad||'').toLowerCase().includes(busq) || (e.cargo||'').toLowerCase().includes(busq);
        const matchEmpresa = !empresa || e.empresa === empresa;
        const matchEstatus = !estatus || e.estatus === estatus;
        return matchBusq && matchEmpresa && matchEstatus;
      });

      renderTabla(filtrados);
      document.getElementById('totalPersonal').textContent = filtrados.length + ' trabajador(es)';
    }

    function renderTabla(data) {
      const tbody = document.getElementById('personalTbody');
      const empty = document.getElementById('personalEmpty');
      if (!data.length) { tbody.innerHTML = ''; empty.style.display = 'block'; return; }
      empty.style.display = 'none';

      tbody.innerHTML = data.map((e, i) => {
        const iniciales = ((e.nombre||'?').charAt(0) + (e.apellido||'?').charAt(0)).toUpperCase();
        const imss = e.imss_vigente === true
          ? '<span style="color:var(--success);font-size:11px">✓ VIGENTE</span>'
          : e.imss_vigente === false
