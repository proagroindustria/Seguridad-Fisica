    async function cambiarEstatus(estatus) {
      const id = currentEmpleadoId;
      if (!id || isNaN(id)) { alert('Error: no se identificó al trabajador'); return; }
      const emp = allPersonal.find(e => e.id === id);
      const nombre = emp ? (emp.nombre||'') + ' ' + (emp.apellido||'') : 'este trabajador';

      if (estatus === 'activo') {
        const inputFecha = document.getElementById('inputFechaInduccion');
        const fechaGuardada = emp?.fecha_induccion;
        const fechaInput = inputFecha?.value;
        if (!fechaGuardada && !fechaInput) {
          const inputEl = document.getElementById('inputFechaInduccion');
          if (inputEl) {
            inputEl.style.borderColor = 'var(--danger)';
            inputEl.focus();
            setTimeout(() => { inputEl.style.borderColor = ''; }, 3000);
          }
          alert('⚠ Debes registrar la fecha de inducción antes de activar al trabajador.');
          return;
        }
      }

      const label = estatus === 'activo' ? 'ACTIVAR' : estatus === 'no_activo' ? 'DESACTIVAR' : 'VETAR';
      if (!confirm('¿Confirmas ' + label + ' a ' + nombre + '?')) return;
      try {
        const r = await fetch('/facial/empleados/' + id + '/estatus', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ estatus })
        });
        const d = await r.json();
        if (!d.success) throw new Error(d.error || 'Error');
        // Auto-guardar fecha_induccion si tiene valor y aún no estaba guardada
        const inputFecha = document.getElementById('inputFechaInduccion');
        if (inputFecha && inputFecha.value && (!emp || !emp.fecha_induccion)) {
          await fetch('/facial/empleados/' + id + '/fecha-induccion', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fecha_induccion: inputFecha.value })
          });
          if (emp) emp.fecha_induccion = inputFecha.value;
        }
        if (emp) { emp.estatus = estatus; emp.activo = estatus === 'activo'; }
        filtrarPersonal();
        cerrarModalTrabajador();
        const msg = document.createElement('div');
        msg.style.cssText = 'position:fixed;bottom:24px;right:24px;background:var(--black);color:var(--accent);padding:14px 20px;font-family:Barlow Condensed,sans-serif;font-size:14px;letter-spacing:1px;z-index:9999;border:1px solid var(--accent)';
        msg.textContent = estatus === 'activo' ? '✓ Trabajador ACTIVADO' : estatus === 'vetado' ? '✗ Trabajador VETADO' : '⏸ Trabajador DESACTIVADO';
        document.body.appendChild(msg);
        setTimeout(() => msg.remove(), 3000);
      } catch(e) {
        alert('Error: ' + e.message);
      }
    }


    function verImgDoc(src) {
  const prev = document.getElementById('imgDocOverlay');
  if (prev) prev.remove();
  
  const overlay = document.createElement('div');
  overlay.id = 'imgDocOverlay';

  overlay.style.cssText = 'position:fixed;inset:0;z-index:99998;background:rgba(0,0,0,0.85);display:flex;align-items:center;justify-content:center';
  overlay.innerHTML = `
    <button onclick="document.getElementById('imgDocOverlay').remove()" style="
      position:fixed;top:20px;right:20px;
      width:36px;height:36px;
      background:#f5a623;color:#000;
      border:none;border-radius:50%;
      font-size:18px;font-weight:700;
      cursor:pointer;z-index:99999;
      display:flex;align-items:center;justify-content:center;
    ">✕</button>
    <img src="${src}" onclick="document.getElementById('imgDocOverlay').remove()"
     style="max-width:90%;max-height:90vh;object-fit:contain;border:2px solid #f5a623;display:block;cursor:zoom-out">
  `;
  
  document.body.appendChild(overlay);

  // ESC handler — se registra UNA sola vez y se limpia solo
  function escHandler(e) {
    if (e.key === 'Escape') {
      const el = document.getElementById('imgDocOverlay');
      if (el) el.remove();
      document.removeEventListener('keydown', escHandler);
    }
  }
  // Eliminar listener viejo si existe
  if (window._imgEscHandler) {
    document.removeEventListener('keydown', window._imgEscHandler);
  }
  window._imgEscHandler = escHandler;
  document.addEventListener('keydown', escHandler);
}





