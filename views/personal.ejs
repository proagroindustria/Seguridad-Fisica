    async function procesarDocEnrol(file, tipo) {
  const procesoEl = document.getElementById(`enrol-${tipo}-proceso`);
  const retryEl   = document.getElementById(`enrol-${tipo}-retry`);
  const dropEl    = document.getElementById(`enrol-${tipo}-drop`);
  const labelEl   = document.getElementById(`enrol-${tipo}-label`);
  const warnEl    = document.getElementById(`warn-${tipo}`);
  procesoEl.style.display = 'block';
  procesoEl.style.color   = 'var(--text-2)';
  procesoEl.innerHTML     = '⏳ Comprimiendo imagen...';
  retryEl.style.display   = 'none';

  try {
    let base64, mimeFinal = file.type;
    if (file.type === 'application/pdf') {
      procesoEl.innerHTML = '⏳ Convirtiendo PDF a imagen...';
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      const page = await pdf.getPage(1);
      const viewport = page.getViewport({ scale: 1.5 });
      const canvas = document.createElement('canvas');
      canvas.width = viewport.width; canvas.height = viewport.height;
      await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
      base64 = canvas.toDataURL('image/jpeg', 0.85).split(',')[1];
      mimeFinal = 'image/jpeg'; 
    } else {
      base64 = await comprimirImagenFrontend(file);
      mimeFinal = 'image/jpeg';
    }

    procesoEl.innerHTML = '⏳ Enviando a procesamiento con IA...';
    const endpoint = tipo === 'imss' ? '/documentos/procesar-imss' : '/documentos/procesar-doc';
    const resp = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ base64, mime: mimeFinal, nombre: file.name, docType: 'AUTO' })
    });
    const data = await resp.json();
    if (!data.success) throw new Error(data.error || 'Error de procesamiento');

    if (tipo === 'cred') {
      const ext = data.extracted || {};

      // ── Detectar tipo de documento ──
      let docType = (ext.tipo_documento || '').toUpperCase();
      if (!docType) {
        if (ext.clave_elector)                               docType = 'INE';
        else if (ext.numero_pasaporte)                       docType = 'PASAPORTE';
        else if (ext.numero_licencia || ext.nombre_conductor) docType = 'LICENCIA';
        else                                                  docType = 'INE';
      }

      // ── Validar vigencia ──
      const hoy = new Date();
      hoy.setHours(0, 0, 0, 0);

      const bloquear = (msg) => {
        procesoEl.innerHTML = msg;
        procesoEl.style.color = 'var(--danger)';
        dropEl.style.borderColor = 'var(--danger)';
        retryEl.style.display = 'block';
        enrolCredFile = null; enrolCredProcesado = false;
        verificarBotonGuardar();
      };

      const parsearFecha = (fechaStr) => {
        if (!fechaStr) return null;
        const partes = String(fechaStr).split('/');
        if (partes.length === 3) {
          const f = new Date(`${partes[2]}-${partes[1].padStart(2,'0')}-${partes[0].padStart(2,'0')}`);
          return isNaN(f.getTime()) ? null : f;
        }
        const f = new Date(fechaStr);
        return isNaN(f.getTime()) ? null : f;
      };

      if (docType === 'INE') {
        if (!ext.vigencia) {
          bloquear(`❌ INE — No se pudo leer la vigencia. Intenta con una imagen más clara.`);
          return;
        }
        const anio = parseInt(String(ext.vigencia).replace(/\D/g, '').slice(-4));
        if (!anio || anio < hoy.getFullYear()) {
          bloquear(`❌ INE VENCIDA — Vigencia: ${ext.vigencia}. No se puede registrar con un documento vencido.`);
          return;
        }
      }

      if (docType === 'PASAPORTE') {
        if (!ext.fecha_vencimiento) {
          bloquear(`❌ PASAPORTE — No se pudo leer la fecha de vencimiento. Intenta con una imagen más clara.`);
          return;
        }
        const fechaVenc = parsearFecha(ext.fecha_vencimiento);
        if (!fechaVenc) {
          bloquear(`❌ PASAPORTE — Fecha de vencimiento no válida: "${ext.fecha_vencimiento}". Intenta con otra imagen.`);
          return;
        }
        if (fechaVenc < hoy) {
          bloquear(`❌ PASAPORTE VENCIDO — Venció: ${ext.fecha_vencimiento}. No se puede registrar con un documento vencido.`);
          return;
        }
      }

        if (docType === 'LICENCIA') {
          const fechaVencRaw = ext.fecha_vencimiento || ext.vigencia || null;
          if (!fechaVencRaw) {
              bloquear(`❌ LICENCIA — No se pudo leer la fecha de vencimiento. Sube una imagen más clara donde se vea la fecha.`);
              return;
            } else {
          const fechaVenc = parsearFecha(fechaVencRaw);
          if (!fechaVenc) {
            procesoEl.innerHTML = `⚠️ LICENCIA — Fecha no reconocida: "${fechaVencRaw}". Verifica manualmente.`;
            procesoEl.style.color = 'var(--warning)';
            dropEl.style.borderColor = 'var(--warning)';
          } else if (fechaVenc < hoy) {
            bloquear(`❌ LICENCIA VENCIDA — Venció: ${fechaVencRaw}. No se puede registrar con un documento vencido.`);
            return;
          }
        }
      }

      // ── Extraer nombre y apellido según tipo ──
      let nombreDoc = '', apellidoDoc = '';
      if (docType === 'LICENCIA') {
        const nc = (ext.nombre_conductor || '').trim();
        const partes = nc.split(' ').filter(Boolean);
        nombreDoc   = partes[0] || '';
        apellidoDoc = partes.slice(1).join(' ');
      } else {
        nombreDoc   = (ext.nombre || '').trim();
        apellidoDoc = [ext.apellido_paterno || '', ext.apellido_materno || ''].filter(Boolean).join(' ');
      }

      // ── Auto-llenar nombre completo ──
      const ncEl = document.getElementById('enrol-nombre_completo');
      const nombreCompleto = [nombreDoc, apellidoDoc].filter(Boolean).join(' ').trim();
      if (ncEl && nombreCompleto) { ncEl.value = nombreCompleto; verificarBotonGuardar(); }

      // ── Todo OK — guardar y mostrar resumen ──
      const docTypeFinal = (ext.tipo_documento || '').toUpperCase() ||
        (ext.clave_elector ? 'INE' :
         ext.numero_pasaporte ? 'PASAPORTE' :
         (ext.numero_licencia || ext.nombre_conductor) ? 'LICENCIA' : 'INE');

      enrolCredProcesado = true;
      enrolCredData = { base64, mime: mimeFinal, nombre: file.name, extracted: ext, docType: docTypeFinal };

      let resumen = '';
      if (docType === 'INE')        resumen = `${ext.nombre || ''} ${ext.apellido_paterno || ''} ${ext.apellido_materno || ''} — Vigencia: ${ext.vigencia || '—'}`;
      else if (docType === 'PASAPORTE') resumen = `${ext.nombre || ''} ${ext.apellido_paterno || ''} — Vence: ${ext.fecha_vencimiento || '—'}`;
      else if (docType === 'LICENCIA')  resumen = `${ext.nombre_conductor || nombreDoc} — Vence: ${ext.fecha_vencimiento || 'no detectada'}`;
      else resumen = `${nombreDoc} ${apellidoDoc}`.trim();

      procesoEl.innerHTML = `✅ ${docType} válido — ${resumen.trim()}`;
      procesoEl.style.color = 'var(--success)';
      dropEl.style.borderColor = 'var(--success)';
      labelEl.textContent = '✅ ' + file.name;
      if (warnEl) warnEl.style.display = 'none';

    } else {
      // ── IMSS ──
      enrolImssProcesado = true;
      enrolImssData = { base64, mime: mimeFinal, nombre: file.name, extracted: data.extracted };
      const vigente = data.extracted?.vigente;
      const nombre  = data.extracted?.nombre_asegurado || '';
      const fecha   = data.extracted?.fecha_vigencia || '';
      procesoEl.innerHTML = vigente
        ? `✅ VIGENTE — ${nombre} — Hasta: ${fecha}`
        : `⚠️ NO VIGENTE — ${nombre}`;
      procesoEl.style.color = vigente ? 'var(--success)' : 'var(--warning)';
      dropEl.style.borderColor = vigente ? 'var(--success)' : 'var(--warning)';
      labelEl.textContent = '✅ ' + file.name;
      if (warnEl) warnEl.style.display = 'none';
    }

  } catch(e) {
    procesoEl.innerHTML = `❌ Error: ${e.message}`;
    procesoEl.style.color = 'var(--danger)';
    dropEl.style.borderColor = 'var(--danger)';
    retryEl.style.display = 'block';
    if (tipo === 'cred') { enrolCredFile = null; enrolCredProcesado = false; }
    else { enrolImssFile = null; enrolImssProcesado = false; }
  }

  verificarBotonGuardar();
}


    function normalizar(str) {
  return (str || '')
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s]/g, '')
    .trim();
}




async function guardarEnrolamiento() {
  const nombreCompleto = document.getElementById('enrol-nombre_completo').value.trim();
  const partes   = nombreCompleto.split(' ').filter(Boolean);
  const nombre   = partes[0] || '';
  const apellido = partes.slice(1).join(' ');
  const nss       = document.getElementById('enrol-nss')?.value?.trim() || null;
  const registro_patronal = null;
  const documento = document.getElementById('enrol-documento').value.trim();
  const area      = document.getElementById('enrol-area').value.trim();
  const cargo     = document.getElementById('enrol-cargo').value.trim();
  const empresa   = document.getElementById('enrol-empresa')?.value.trim() || '';

  // Sin validaciones aquí — verificarBotonGuardar ya garantizó que todo está bien

  const btn      = document.getElementById('btn-enrol-guardar');
  const statusEl = document.getElementById('enrol-save-status');
  btn.disabled = true; btn.textContent = '⏳ Procesando...';
  statusEl.style.display = 'block'; statusEl.textContent = 'Registrando empleado...';

  try {
    const rEmp = await Facial.enrolar({
      nombre, apellido, email: null, documento, area, cargo, empresa,
      descriptor: facialDescriptorEnrol,
      estatus: 'no_activo',
      imss_nss: nss || null,
      registro_patronal
    });
    if (!rEmp.success) throw new Error(rEmp.error || 'Error al registrar empleado');
    const empleadoId = rEmp.empleado.id;

    statusEl.textContent = 'Guardando credencial...';
    await fetch('/documentos/subir', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ archivos: [{ nombre: enrolCredData.nombre, mime: enrolCredData.mime, base64: enrolCredData.base64, tipo: 'DOC' }], empleado_id: empleadoId })
    }).then(r => r.json());

    if (enrolImssData) {
      statusEl.textContent = 'Guardando vigencia IMSS...';
      await fetch('/documentos/subir', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ archivos: [{ nombre: enrolImssData.nombre, mime: enrolImssData.mime, base64: enrolImssData.base64, tipo: 'IMSS' }], empleado_id: empleadoId })
      }).then(r => r.json());
    }

    statusEl.textContent = '✅ Personal registrado con estatus NO ACTIVO';
    statusEl.style.color = 'var(--success)';
    setTimeout(() => { cerrarFacialEnrolar(); }, 1500);

  } catch(e) {
     statusEl.textContent = '❌ Error: ' + e.message;
    statusEl.style.color = 'var(--danger)';
    btn.disabled = false;
    btn.textContent = 'REGISTRAR PERSONAL'; // ← esta línea falta

  }
}









    async function guardarFechaInduccion() {
  const id = currentEmpleadoId;
  const fecha = document.getElementById('inputFechaInduccion').value;
  if (!id) return;
  try {
    const r = await fetch('/facial/empleados/' + id + '/fecha-induccion', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ fecha_induccion: fecha || null })
    });
    const d = await r.json();
    if (!d.success) throw new Error(d.error);
    const emp = allPersonal.find(e => e.id === id);
    if (emp) emp.fecha_induccion = fecha || null;
    const msg = document.createElement('div');
    msg.style.cssText = 'position:fixed;bottom:24px;right:24px;background:var(--black);color:var(--accent);padding:14px 20px;font-family:Barlow Condensed,sans-serif;font-size:14px;letter-spacing:1px;z-index:9999;border:1px solid var(--accent)';
    msg.textContent = '✓ Fecha de inducción guardada';
    document.body.appendChild(msg);
    setTimeout(() => msg.remove(), 3000);
  } catch(e) {
    alert('Error: ' + e.message);
  }
}



async function liberarTrabajador() {
  const id = currentEmpleadoId;
  if (!id) return;

  const emp = allPersonal.find(e => e.id === id);
  const nombre = emp ? `${emp.nombre} ${emp.apellido}` : 'este trabajador';

  if (!confirm(
    `¿Confirmas LIBERAR a ${nombre}?\n\n` +
    `Esto borrará su registro facial y lo desvinculará de ${emp?.empresa || 'la empresa'}.\n` +
    `Su historial de accesos se conservará.\n\n` +
    `Para volver a trabajar deberá ser re-enrolado desde cero.`
  )) return;

  try {
    const r = await fetch(`/facial/empleados/${id}/liberar`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' }
    });
    const d = await r.json();
    if (!d.success) throw new Error(d.error || 'Error');

    cerrarModalTrabajador();
    await cargarPersonal();

    const msg = document.createElement('div');
    msg.style.cssText = 'position:fixed;bottom:24px;right:24px;background:var(--black);color:#8b5cf6;padding:14px 20px;font-family:Barlow Condensed,sans-serif;font-size:14px;letter-spacing:1px;z-index:9999;border:1px solid #8b5cf6';
    msg.textContent = `✂ ${nombre} liberado — puede re-enrolarse en otra empresa`;
    document.body.appendChild(msg);
    setTimeout(() => msg.remove(), 4000);

  } catch(e) {
    alert('Error: ' + e.message);
  }
}




