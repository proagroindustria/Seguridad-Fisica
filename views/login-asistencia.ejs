<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PROAGRO — Registro de Asistencia</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800&family=Barlow:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/login.css">
  <style>
    .brand-panel {
      background: var(--accent);
      border-right-color: var(--black);
    }
    .brand-panel::before {
      background: radial-gradient(circle, rgba(0,0,0,0.08) 0%, transparent 70%);
    }
    .brand-panel::after {
      background: radial-gradient(circle, rgba(0,0,0,0.05) 0%, transparent 70%);
    }
    .grid-overlay {
      background-image:
        linear-gradient(rgba(0,0,0,0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,0,0,0.07) 1px, transparent 1px);
    }
    .logo-mark        { background: var(--black); }
    .logo-mark span   { color: var(--accent); }
    .brand-name       { color: var(--black); }
    .brand-subtitle   { color: rgba(0,0,0,0.65); }
    .brand-divider    { background: var(--black); }
    .brand-desc       { color: rgba(0,0,0,0.55); }
    .status-dot       { background: var(--black); box-shadow: 0 0 8px rgba(0,0,0,0.3); }
    .status-text      { color: var(--black); }
  </style>
</head>
<body>
  <div class="login-bg">
    <div class="grid-overlay"></div>
    <div class="scanline"></div>
  </div>

  <div class="login-container">
    <div class="brand-panel">
      <div class="brand-logo">
        <div class="logo-mark"><span>P</span></div>
      </div>
      <h1 class="brand-name">PROAGRO</h1>
      <p class="brand-subtitle">REGISTRO DE ASISTENCIA</p>
      <div class="brand-divider"></div>
      <p class="brand-desc">Acceso exclusivo para el módulo de control de entradas y salidas de personal.</p>
      <div class="status-bar">
        <span class="status-dot"></span>
        <span class="status-text">MÓDULO BIOMÉTRICO</span>
      </div>
    </div>

    <div class="form-panel">
      <div class="form-header">
        <p class="form-label">ACCESO CONTROLADO</p>
        <h2 class="form-title">Registro de Asistencia</h2>
      </div>

      <% if (error) { %>
      <div class="alert-error">
        <span class="alert-icon">⚠</span>
        <span><%= error %></span>
      </div>
      <% } %>

      <form action="/login-asistencia" method="POST" class="login-form">
        <div class="field-group">
          <label class="field-label" for="username">USUARIO</label>
          <div class="field-wrapper">
            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <input type="text" id="username" name="username" class="field-input"
              placeholder="Ingresa tu usuario" autocomplete="off" required />
          </div>
        </div>

        <div class="field-group">
          <label class="field-label" for="password">CONTRASEÑA</label>
          <div class="field-wrapper">
            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <input type="password" id="password" name="password" class="field-input"
              placeholder="••••••••" required />
          </div>
        </div>

        <button type="submit" class="btn-login">
          <span>INGRESAR</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </form>

      <div style="margin-top: 16px; text-align: center;">
        <a href="/login" style="
          font-family:'Share Tech Mono',monospace;
          font-size:11px;
          color:#555;
          text-decoration:none;
          letter-spacing:1px;
          transition: color 0.2s;
        "
        onmouseover="this.style.color='#c8a84b'"
        onmouseout="this.style.color='#555'"
        >← VOLVER AL LOGIN PRINCIPAL</a>
      </div>

      <div class="form-footer">
        <div class="footer-line">
          <span class="mono-text">v1.0.0</span>
          <span class="footer-sep">|</span>
          <span class="mono-text">MÓDULO ASISTENCIA</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const panels = document.querySelectorAll('.brand-panel, .form-panel');
      panels.forEach((el, i) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        setTimeout(() => {
          el.style.transition = 'all 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, 100 + i * 150);
      });
    });
  </script>
</body>
</html>