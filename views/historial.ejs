<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro de Incidencias — PROAGRO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800&family=Barlow:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
</head>
<body>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">
        <div class="logo-mark-sm">P</div>
        <div><span class="sidebar-brand">PROAGRO</span><span class="sidebar-version">v1.0.0</span></div>
      </div>
      <button class="sidebar-close" onclick="closeSidebar()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
      <div class="user-info">
        <span class="user-name"><%= user.nombre_completo %></span>
        <span class="user-role-badge role-<%= user.rol %>">VIG. FÍSICA</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <p class="nav-section-label">NAVEGACIÓN</p>
      <a href="/dashboard" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
        <span>Solicitudes</span>
      </a>
      <a href="/personal" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>Trabajadores Contratistas</span>
      </a>
      <a href="/historial" class="nav-item active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/></svg>
        <span>Registro de Incidencias</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/logout" class="nav-item nav-logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        <span>Cerrar Sesión</span>
      </a>
    </div>
  </aside>

  <div class="main-wrapper">
    <div class="topbar">
      <div class="topbar-left">
        <button class="menu-toggle" onclick="openSidebar()"><span></span><span></span><span></span></button>
        <div class="topbar-brand">
          <div class="topbar-logo-mark">P</div>
          <span class="topbar-title">PROAGRO</span>
          <span class="topbar-sep">/</span>
          <span class="topbar-section">Historial de Accesos</span>
        </div>
      </div>
      <div class="topbar-right">
        <button onclick="exportarExcel()" class="btn-excel" style="display:flex;align-items:center;gap:6px;padding:8px 14px">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:15px;height:15px"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
          EXPORTAR EXCEL
        </button>
        <div style="position:relative" id="notifWrapper">
          <button onclick="toggleNotificaciones()" style="background:none;border:none;cursor:pointer;color:var(--text);position:relative;padding:6px;display:flex;align-items:center">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" style="width:22px;height:22px">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            <span id="notifBadge" style="display:none;position:absolute;top:0;right:0;background:#ef4444;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;min-width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;padding:0 3px">0</span>
          </button>
          <div id="notifPanel" style="display:none;position:absolute;right:0;top:calc(100% + 8px);width:340px;background:var(--bg-2);border:1px solid var(--border);box-shadow:0 8px 24px rgba(0,0,0,0.3);z-index:999;max-height:400px;overflow-y:auto">
            <div style="padding:14px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
              <span style="font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;color:var(--accent)">NOTIFICACIONES</span>
              <span id="notifTotal" style="font-size:11px;color:var(--text-3);font-family:'Share Tech Mono',monospace"></span>
            </div>
            <div id="notifLista"><div style="padding:20px;text-align:center;color:var(--text-3);font-size:13px">Cargando...</div></div>
          </div>
        </div>
        <div class="topbar-user">
          <div class="topbar-avatar"><%= user.nombre_completo.charAt(0).toUpperCase() %></div>
          <span class="topbar-username"><%= user.username %></span>
        </div>
      </div>
    </div>

    <div class="page-content">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">VIGILANCIA FÍSICA</p>
          <h1 class="section-title">Registro de Incidencias</h1>
        </div>
        <div class="filter-bar" style="flex-wrap:wrap;gap:10px">
          <div class="search-box" style="min-width:200px">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="text" id="searchHistorial" placeholder="Buscar por nombre..." oninput="filtrarHistorial()">
          </div>
          <select id="filtroMovimiento" onchange="filtrarHistorial()"
            style="padding:9px 14px;background:var(--bg-2);border:1px solid var(--border);color:var(--text);font-family:'Barlow',sans-serif;font-size:13px">
            <option value="">Todos</option>
            <option value="entrada">Entradas</option>
            <option value="salida">Salidas</option>
          </select>
          <div style="font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--text-3)" id="totalHistorial"></div>
        </div>
      </div>

      <div class="table-container" style="display:flex;flex-direction:column;max-height:calc(100vh - 210px)">
        <div id="tableBody" style="overflow-y:auto;flex:1">
          <div id="histLoading" class="table-loading">
            <div class="loading-spinner"></div>
            <span>Cargando historial...</span>
          </div>
          <table class="data-table" id="histTable" style="display:none">
            <thead>
              <tr>
                <th>FECHA / HORA</th>
                <th>MOVIMIENTO</th>
                <th>RESULTADO</th>
                <th>EMPLEADO</th>
                <th>ÁREA</th>
                <th>EMPRESA</th>
                <th>SIMILITUD</th>
                <th>IP</th>
              </tr>
            </thead>
            <tbody id="histTbody"></tbody>
          </table>
          <div id="histEmpty" style="display:none;padding:60px;text-align:center;color:var(--text-3)">Sin registros de acceso.</div>
        </div>

        <div id="paginacionHist" style="display:none;flex-shrink:0;padding:16px 20px;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;border-top:1px solid var(--border)">
          <div style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text-3)" id="paginaInfo"></div>
          <div style="display:flex;align-items:center;gap:6px">
            <select id="porPagina" onchange="cambiarPorPagina()" style="padding:6px 10px;background:var(--bg-2);border:1px solid var(--border);color:var(--text);font-family:'Barlow',sans-serif;font-size:12px">
              <option value="25">25 por página</option>
              <option value="50" selected>50 por página</option>
              <option value="100">100 por página</option>
              <option value="200">200 por página</option>
            </select>
            <button id="btnPrimera" onclick="irPagina(1)" style="padding:6px 10px;background:var(--bg-2);border:1px solid var(--border);color:var(--text);font-family:'Barlow Condensed',sans-serif;font-size:12px;cursor:pointer">«</button>
            <button id="btnAnterior" onclick="irPagina(paginaActual-1)" style="padding:6px 10px;background:var(--bg-2);border:1px solid var(--border);color:var(--text);font-family:'Barlow Condensed',sans-serif;font-size:12px;cursor:pointer">‹ ANT</button>
            <div id="numPaginas" style="display:flex;gap:4px"></div>
            <button id="btnSiguiente" onclick="irPagina(paginaActual+1)" style="padding:6px 10px;background:var(--bg-2);border:1px solid var(--border);color:var(--text);font-family:'Barlow Condensed',sans-serif;font-size:12px;cursor:pointer">SIG ›</button>
            <button id="btnUltima" onclick="irPagina(totalPaginas)" style="padding:6px 10px;background:var(--bg-2);border:1px solid var(--border);color:var(--text);font-family:'Barlow Condensed',sans-serif;font-size:12px;cursor:pointer">»</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function openSidebar()  { document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebarOverlay').classList.add('open'); }
    function closeSidebar() { document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarOverlay').classList.remove('open'); }

    let allAccesos = [];
    let filtradosActual = [];
    let paginaActual = 1;
    let totalPaginas = 1;

    async function cargarHistorial() {
      try {
        const r = await fetch('/facial/accesos');
        const d = await r.json();
        if (!d.success) throw new Error(d.error);
        allAccesos = d.data;
        filtrarHistorial();
        document.getElementById('histLoading').style.display = 'none';
        document.getElementById('histTable').style.display = 'table';
      } catch(e) {
        document.getElementById('histLoading').innerHTML = '<span style="color:var(--danger)">Error: ' + e.message + '</span>';
      }
    }

    function filtrarHistorial() {
      const busq = document.getElementById('searchHistorial').value.toLowerCase();
      const mov  = document.getElementById('filtroMovimiento').value;

      filtradosActual = allAccesos.filter(a => {
        const nombre = (a.nombre_completo||'').toLowerCase();
        return (!busq || nombre.includes(busq)) && (!mov || a.tipo_movimiento === mov);
      });

      document.getElementById('totalHistorial').textContent = filtradosActual.length + ' registro(s)';
      irPagina(1);
    }

    function cambiarPorPagina() {
      irPagina(1);
    }

    function irPagina(n) {
      const porPagina = parseInt(document.getElementById('porPagina').value);
      totalPaginas = Math.max(1, Math.ceil(filtradosActual.length / porPagina));
      paginaActual = Math.min(Math.max(1, n), totalPaginas);

      const inicio = (paginaActual - 1) * porPagina;
      const fin    = inicio + porPagina;
      renderHistorial(filtradosActual.slice(inicio, fin));
      actualizarPaginacion(porPagina);
    }

    function actualizarPaginacion(porPagina) {
      const pag = document.getElementById('paginacionHist');
      const empty = document.getElementById('histEmpty');

      if (!filtradosActual.length) {
        pag.style.display = 'none';
        return;
      }

      pag.style.display = 'flex';

      const inicio = (paginaActual - 1) * porPagina + 1;
      const fin    = Math.min(paginaActual * porPagina, filtradosActual.length);
      document.getElementById('paginaInfo').textContent =
        'Mostrando ' + inicio + '–' + fin + ' de ' + filtradosActual.length + ' registros';

      document.getElementById('btnPrimera').disabled  = paginaActual === 1;
      document.getElementById('btnAnterior').disabled = paginaActual === 1;
      document.getElementById('btnSiguiente').disabled = paginaActual === totalPaginas;
      document.getElementById('btnUltima').disabled    = paginaActual === totalPaginas;

      // Números de página (ventana de 5)
      const numDiv = document.getElementById('numPaginas');
      let html = '';
      const ventana = 2;
      for (let i = 1; i <= totalPaginas; i++) {
        if (i === 1 || i === totalPaginas || (i >= paginaActual - ventana && i <= paginaActual + ventana)) {
          const activo = i === paginaActual
            ? 'background:var(--accent);color:#fff;border-color:var(--accent)'
            : 'background:var(--bg-2);color:var(--text);border-color:var(--border)';
          html += '<button onclick="irPagina(' + i + ')" style="padding:6px 10px;border:1px solid;font-family:Barlow Condensed,sans-serif;font-size:12px;cursor:pointer;' + activo + '">' + i + '</button>';
        } else if (
          (i === paginaActual - ventana - 1 && i > 1) ||
          (i === paginaActual + ventana + 1 && i < totalPaginas)
        ) {
          html += '<span style="padding:6px 4px;color:var(--text-3);font-size:12px">…</span>';
        }
      }
      numDiv.innerHTML = html;
    }

    function renderHistorial(data) {
      const tbody = document.getElementById('histTbody');
      const empty = document.getElementById('histEmpty');
      if (!data.length) { tbody.innerHTML = ''; empty.style.display = 'block'; return; }
      empty.style.display = 'none';

      tbody.innerHTML = data.map(a => {
        const fecha = a.fecha_hora ? new Date(a.fecha_hora).toLocaleString('es-MX',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—';
        const nombre = a.nombre_completo || 'Desconocido';
        const similitud = a.similitud ? (parseFloat(a.similitud)*100).toFixed(1)+'%' : '—';
        const esEntrada = a.tipo_movimiento === 'entrada';
        const movColor = esEntrada ? 'var(--success)' : 'var(--danger)';
        const movLabel = (esEntrada ? '↓ ENTRADA' : '↑ SALIDA');
        const resClass = a.resultado === 'exitoso' ? 'badge-exitoso' : 'badge-fallido';

        return '<tr style="border-bottom:1px solid var(--border)">' +
          '<td style="font-family:Share Tech Mono,monospace;font-size:11px;color:var(--text-3)">' + fecha + '</td>' +
          '<td style="font-weight:700;color:' + movColor + ';font-family:Barlow Condensed,sans-serif;font-size:13px">' + movLabel + '</td>' +
          '<td class="' + resClass + '">' + (a.resultado === 'exitoso' ? '✅' : '❌') + ' ' + a.resultado + '</td>' +
          '<td style="font-weight:500;color:var(--text)">' + nombre + '</td>' +
          '<td style="color:var(--text-2)">' + (a.area||'—') + '</td>' +
          '<td style="color:var(--text-2)">' + (a.empresa||'—') + '</td>' +
          '<td style="font-family:Share Tech Mono,monospace;font-size:11px;color:var(--text-3)">' + similitud + '</td>' +
          '<td style="font-family:Share Tech Mono,monospace;font-size:11px;color:var(--text-3)">' + (a.ip_origen||'—') + '</td>' +
        '</tr>';
      }).join('');
    }

    function exportarExcel() {
      if (!allAccesos.length) { alert('No hay datos para exportar'); return; }
      const ws = XLSX.utils.json_to_sheet(allAccesos.map(a => ({
        'Fecha/Hora': a.fecha_hora ? new Date(a.fecha_hora).toLocaleString('es-MX') : '',
        'Movimiento': a.tipo_movimiento,
        'Resultado':  a.resultado,
        'Empleado':   a.nombre_completo || '',
        'Área':       a.area || '',
        'Empresa':    a.empresa || '',
        'Similitud':  a.similitud ? (parseFloat(a.similitud)*100).toFixed(1)+'%' : '',
        'IP':         a.ip_origen || '',
      })));
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, 'Accesos');
      XLSX.writeFile(wb, 'PROAGRO_Accesos_' + new Date().toLocaleDateString('es-MX').replace(/\//g,'-') + '.xlsx');
    }

    cargarHistorial();
  </script>
  <script>const USER_ROL = '<%= user.rol %>';</script>
  <script src="/js/notificaciones.js"></script>
</body>
</html>
