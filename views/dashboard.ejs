<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PROAGRO — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800&family=Barlow:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
  <script src="/js/facial.js"></script>
</head>
<body>

  <!-- SIDEBAR SLICE -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">
        <div class="logo-mark-sm">P</div>
        <div>
          <span class="sidebar-brand">PROAGRO</span>
          <span class="sidebar-version">v1.0.0</span>
        </div>
      </div>
      <button class="sidebar-close" onclick="closeSidebar()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="sidebar-user">
      <div class="user-avatar">
        <%= user.username.charAt(0).toUpperCase() %>
      </div>
      <div class="user-info">
        <span class="user-name"><%= user.nombre_completo %></span>
        <span class="user-role-badge role-<%= user.rol %>">
          <%= user.rol === 'area' ? 'ÁREA' : user.rol === 'seguridad_fisica' ? 'SEG. FÍSICA' : 'CONTRATISTA' %>
        </span>
      </div>
    </div>

    <nav class="sidebar-nav">
      <p class="nav-section-label">NAVEGACIÓN</p>
      <a href="#" class="nav-item active" onclick="showSection('solicitudes')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14,2 14,8 20,8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10,9 9,9 8,9"/>
        </svg>
        <span>Solicitudes</span>
      </a>
      <% if (user.rol === 'contratista') { %>


      <a href="/personal" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span>Mi Personal</span>
      </a>
      <a href="#" class="nav-item" onclick="abrirFacialEnrolar(); closeSidebar();">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <line x1="19" y1="8" x2="19" y2="14"/>
          <line x1="22" y1="11" x2="16" y2="11"/>
        </svg>
        <span>Gestión de Trabajadores</span>
      </a>
      <% } %>
      <% if (user.rol === 'seguridad_fisica') { %>
      <a href="/personal" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span>Trabajadores Contratistas</span>
      </a>
      <a href="/verificar" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="8" r="4"/>
          <path d="M3 20c0-4 4-7 9-7s9 3 9 7"/>
        </svg>
        <span>Registro de Asistencia</span>
      </a>
      <a href="/historial" class="nav-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/>
        </svg>
        <span>Registro de Incidencias</span>
      </a>
      <% } %>

    </nav>

    <div class="sidebar-footer">
      <a href="/logout" class="nav-item nav-logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16,17 21,12 16,7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        <span>Cerrar Sesión</span>
      </a>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <div class="main-wrapper">

    <!-- TOPBAR -->
    <header class="topbar">
      <div class="topbar-left">
        <button class="menu-toggle" onclick="openSidebar()">
          <span></span><span></span><span></span>
        </button>
        <div class="topbar-brand">
          <span class="topbar-logo-mark">P</span>
          <span class="topbar-title">PROAGRO</span>
          <span class="topbar-sep">/</span>
          <span class="topbar-section">Sistema de Solicitudes</span>
        </div>
      </div>
      <div class="topbar-right">
        <div class="topbar-user">
          <div class="topbar-avatar">
            <%= user.username.charAt(0).toUpperCase() %>
          </div>
          <span class="topbar-username"><%= user.username %></span>
        </div>
      </div>
    </header>

    <!-- PAGE CONTENT -->
    <main class="page-content">

      <!-- SECTION HEADER -->
      <div class="section-header">
        <div class="section-title-group">
          <p class="section-eyebrow">GESTIÓN</p>
          <h1 class="section-title">Solicitudes de Acceso</h1>
        </div>

        <div class="section-actions">
          <div class="stats-bar">
            <div class="stat-chip" id="statTotal">
              <span class="stat-num" id="numTotal">0</span>
              <span class="stat-label">Total</span>
            </div>
            <div class="stat-chip stat-pendiente">
              <span class="stat-num" id="numPendiente">0</span>
              <span class="stat-label">Pendientes</span>
            </div>
            <div class="stat-chip stat-aprobado">
              <span class="stat-num" id="numAprobado">0</span>
              <span class="stat-label">Aprobados</span>
            </div>
          </div>

          <% if (user.rol === 'contratista') { %>
          <button class="btn-primary" onclick="openModalSolicitud()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            NUEVA SOLICITUD
          </button>
          <% } %>
        </div>
      </div>

      <!-- BOTONES RECONOCIMIENTO FACIAL -->


      <!-- FILTERS -->
      <div class="filter-bar">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" id="searchInput" placeholder="Buscar por empresa, contrato o folio..." oninput="filterTable()">
        </div>
        <div class="filter-chips">
          <button class="filter-chip active" data-filter="todos"                onclick="setFilter('todos', this)">Todos</button>
          <button class="filter-chip" data-filter="en_espera_area"              onclick="setFilter('en_espera_area', this)">Esp. Área</button>
          <button class="filter-chip" data-filter="en_espera_seguridad"         onclick="setFilter('en_espera_seguridad', this)">Esp. Seguridad</button>
          <button class="filter-chip" data-filter="activo"                      onclick="setFilter('activo', this)">Activos</button>
          <button class="filter-chip" data-filter="rechazado"                   onclick="setFilter('rechazado', this)">Rechazados</button>
          <button class="filter-chip" data-filter="vencido"                     onclick="setFilter('vencido', this)">Vencidos</button>
        </div>
      </div>

      <!-- TABLE -->
      <div class="table-container">
        <div class="table-loading" id="tableLoading">
          <div class="loading-spinner"></div>
          <span>Cargando solicitudes...</span>
        </div>

        <table class="data-table" id="dataTable">
          <thead>
            <tr>
              <th>FOLIO</th>
              <th>EMPRESA</th>
              <th>CONTRATO</th>
              <th>RESPONSABLE</th>
              <th>FECHA INICIO</th>
              <th>FECHA FIN</th>
              <th>DURACIÓN</th>
              <th>ESTADO</th>
              <% if (user.rol !== 'contratista') { %>
              <th>ACCIONES</th>
              <% } %>
            </tr>
          </thead>
          <tbody id="tableBody">
            <!-- Populated by JS -->
          </tbody>
        </table>

        <div class="empty-state" id="emptyState" style="display:none;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14,2 14,8 20,8"/>
          </svg>
          <p>No se encontraron solicitudes</p>
          <% if (user.rol === 'contratista') { %>
          <button class="btn-primary" onclick="openModalSolicitud()">Crear primer solicitud</button>
          <% } %>
        </div>
      </div>

    </main>
  </div>

  <!-- MODAL NUEVA SOLICITUD -->
  <% if (user.rol === 'contratista') { %>
  <div class="modal-overlay" id="modalSolicitud">
    <div class="modal-box modal-box-xl">

      <!-- HEADER -->
      <div class="modal-header">
        <div>
          <p class="modal-eyebrow">CONTRATISTA</p>
          <h2 class="modal-title">Nueva Solicitud de Acceso</h2>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
          <button class="modal-close" onclick="closeModal()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="modal-alert" id="modalAlert" style="display:none;"></div>

      <form id="formSolicitud" class="modal-form">

        <!-- PASO 1: DATOS GENERALES -->
        <div class="form-section">
          <p class="form-section-label">— DATOS GENERALES</p>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">EMPRESA <span class="required">*</span></label>
              <input type="text" name="empresa" id="empresa" class="form-input"
              placeholder="Nombre de la empresa"
              value="<% if (user.rol === 'contratista') { %><%= user.nombre_completo %><% } %>"
              <% if (user.rol === 'contratista') { %>readonly class="form-input form-input-readonly"<% } %>
              required>
            <% if (user.rol === 'contratista') { %>
            <p class="form-hint">Asignado automáticamente a tu cuenta.</p>
            <% } %>
            </div>
            <div class="form-group">
              <label class="form-label">CONTRATO <span class="required">*</span></label>
              <input type="text" name="contrato" id="contrato" class="form-input" placeholder="Número o nombre del contrato" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">RESPONSABLE DEL CONTRATO</label>
            <input type="text" name="responsable_contrato" value="PROAGRO" class="form-input form-input-readonly" readonly>
            <p class="form-hint">Asignado automáticamente.</p>
          </div>
        </div>

        <!-- PASO 2: FECHAS CON CALENDARIO -->
        <div class="form-section">
          <p class="form-section-label">— PERÍODO DE ACCESO</p>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">FECHA DE INICIO <span class="required">*</span></label>
              <div class="date-input-wrapper">
                <svg class="date-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <input type="date" name="fecha_inicio" id="fecha_inicio" class="form-input date-input" required onchange="validateFechas()">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">FECHA FIN <span class="required">*</span></label>
              <div class="date-input-wrapper">
                <svg class="date-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <input type="date" name="fecha_fin" id="fecha_fin" class="form-input date-input" required onchange="validateFechas()">
              </div>
              <p class="form-hint" id="fechaHint">Máximo 30 días desde la fecha de inicio.</p>
            </div>
          </div>
          <div class="form-dias" id="formDias" style="display:none;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span id="diasTexto">0 días de duración</span>
          </div>
        </div>

        <!-- PASO 3: DRAG & DROP DE SECCIONES -->
        <div class="form-section">
          <p class="form-section-label">— SECCIONES DE LA SOLICITUD <span class="hint-label">(arrastra para agregar)</span></p>

          <!-- PALETA DE TARJETAS DISPONIBLES -->
          <div class="dnd-palette" id="dndPalette">
            <div class="dnd-card-source" draggable="true" data-type="personal"
                 ondragstart="onDragStart(event)" ondragend="onDragEnd(event)">
              <div class="dnd-card-icon dnd-icon-personal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              </div>
              <div class="dnd-card-info">
                <span class="dnd-card-title">Personal</span>
                <span class="dnd-card-desc">Credencial, nombre, categoría</span>
              </div>
              <div class="dnd-drag-handle">⠿</div>
            </div>

            <div class="dnd-card-source" draggable="true" data-type="vehiculo"
                 ondragstart="onDragStart(event)" ondragend="onDragEnd(event)">
              <div class="dnd-card-icon dnd-icon-vehiculo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="1" y="3" width="15" height="13" rx="1"/>
                  <path d="M16 8h4l3 5v3h-7V8z"/>
                  <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                </svg>
              </div>
              <div class="dnd-card-info">
                <span class="dnd-card-title">Vehículo</span>
                <span class="dnd-card-desc">Marca, modelo, placas, seguro</span>
              </div>
              <div class="dnd-drag-handle">⠿</div>
            </div>

            <div class="dnd-card-source" draggable="true" data-type="equipo"
                 ondragstart="onDragStart(event)" ondragend="onDragEnd(event)">
              <div class="dnd-card-icon dnd-icon-equipo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
              </div>
              <div class="dnd-card-info">
                <span class="dnd-card-title">Equipo / Herramientas</span>
                <span class="dnd-card-desc">Cantidad, descripción, marca</span>
              </div>
              <div class="dnd-drag-handle">⠿</div>
            </div>
          </div>

          <!-- ZONA DE DROP -->
          <div class="dnd-drop-zone" id="dndDropZone"
               ondragover="onDragOver(event)" ondragleave="onDragLeave(event)" ondrop="onDrop(event)">
            <div class="dnd-drop-placeholder" id="dndPlaceholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 5v14M5 12h14"/>
              </svg>
              <span>Arrastra las secciones aquí</span>
            </div>
            <!-- Secciones agregadas aparecen aquí -->
          </div>
        </div>

        <!-- FOOTER -->
        <div class="modal-footer">
          <button type="button" class="btn-secondary" onclick="closeModal()">Cancelar</button>
          <button type="submit" class="btn-primary" id="btnSubmit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="20,6 9,17 4,12"/>
            </svg>
            CREAR SOLICITUD
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- SUB-MODAL: FORMULARIO DE SECCIÓN -->
  <div class="submodal-overlay" id="subModal">
    <div class="submodal-box" id="subModalBox">
      <div class="submodal-header">
        <div>
          <p class="modal-eyebrow" id="subModalEyebrow">SECCIÓN</p>
          <h3 class="submodal-title" id="subModalTitle">Formulario</h3>
        </div>
        <button class="modal-close" onclick="closeSubModal()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="submodal-body" id="subModalBody"></div>
      <div class="submodal-footer">
        <button type="button" class="btn-secondary" onclick="closeSubModal()">Cancelar</button>
        <button type="button" class="btn-primary" onclick="guardarSeccion()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="20,6 9,17 4,12"/>
          </svg>
          GUARDAR
        </button>
      </div>
    </div>
  </div>

  <% } %>


  <!-- MODAL DETALLE SOLICITUD -->
  <div class="modal-overlay" id="modalDetalle">
    <div class="modal-box modal-box-xl" id="modalDetalleBox">
      <div class="modal-header">
        <div>
          <p class="modal-eyebrow" id="detalleEyebrow">SOLICITUD</p>
          <h2 class="modal-title" id="detalleFolio">Cargando...</h2>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
          <div id="detalleBtnAcciones"></div>
          <button class="modal-close" onclick="closeDetalleBtn()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="detalle-body" id="detalleBody">
        <div class="table-loading">
          <div class="loading-spinner"></div>
          <span>Cargando información...</span>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL MOTIVO RECHAZO -->
  <div class="submodal-overlay" id="modalMotivo">
    <div class="submodal-box" style="max-width:440px;">
      <div class="submodal-header">
        <div>
          <p class="modal-eyebrow" style="color:#ef4444;">RECHAZAR SOLICITUD</p>
          <h3 class="submodal-title">Motivo de Rechazo</h3>
        </div>
        <button class="modal-close" onclick="closeMotivo()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="submodal-body">
        <div class="form-group">
          <label class="form-label">MOTIVO (opcional)</label>
          <textarea id="motivoTexto" class="form-input" rows="4" style="resize:vertical;font-family:inherit;font-size:14px;"
            placeholder="Describe el motivo del rechazo..."></textarea>
        </div>
      </div>
      <div class="submodal-footer">
        <button type="button" class="btn-secondary" onclick="closeMotivo()">Cancelar</button>
        <button type="button" class="btn-danger" id="btnConfirmarRechazo" onclick="confirmarRechazo()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:15px;height:15px">
            <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
          CONFIRMAR RECHAZO
        </button>
      </div>
    </div>
  </div>

  <script>
    const USER_ROL = '<%= user.rol %>';
    const USER_ID = '<%= user.id %>';
  </script>
  <script>
    window._userRol = '<%= user.rol %>';
    window._userEmpresa = '<%= user.nombre_completo %>';
    // Abrir modal de enrolamiento si viene con ?accion=enrolar
    window.addEventListener('load', () => {
      const params = new URLSearchParams(window.location.search);
      if (params.get('accion') === 'enrolar') {
        setTimeout(() => abrirFacialEnrolar(), 500);
      }
    });
  </script>
  <script src="/js/dashboard.js"></script>
  <script src="/js/documentos.js"></script>

  <!-- MODAL QR -->
  <div class="modal-overlay" id="modalQR">
    <div class="modal-box" style="max-width:480px;text-align:center" id="modalQRBox">
      <div class="modal-header">
        <div>
          <p class="modal-eyebrow" style="color:var(--accent)">SOLICITUD ACTIVO</p>
          <h2 class="modal-title" id="qrFolio">—</h2>
        </div>
        <button class="modal-close" onclick="closeQRBtn()">
