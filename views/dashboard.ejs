        <button class="modal-close" onclick="cerrarFacialHistorial()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px;height:18px"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="facial-body">
        <div id="historial-loading" class="facial-status">⏳ Cargando...</div>
        <div style="overflow-x:auto">
          <table class="accesos-table" id="historial-table" style="display:none">
            <thead><tr><th>Fecha / Hora</th><th>Movimiento</th><th>Resultado</th><th>Empleado</th><th>Área</th><th>Similitud</th></tr></thead>
            <tbody id="historial-body"></tbody>
          </table>
        </div>
        <div style="margin-top:14px;display:flex;gap:10px;justify-content:center">
          <button class="btn-facial" onclick="exportarAccesosExcel()">EXPORTAR EXCEL</button>
          <button class="btn-secondary" onclick="cerrarFacialHistorial()">Cerrar</button>
        </div>
      </div>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════
       MODAL: MIS DOCUMENTOS (Contratista)
  ═══════════════════════════════════════════════ -->
  <div class="modal-overlay" id="modalMisDocumentos">
    <div class="modal-box modal-box-xl" style="max-height:90vh;display:flex;flex-direction:column">
      <div class="modal-header">
        <div>
          <p class="modal-eyebrow">CONTRATISTA</p>
          <h2 class="modal-title">Documentos</h2>
        </div>
        <button class="modal-close" onclick="document.getElementById('modalMisDocumentos').classList.remove('open');document.body.style.overflow=''">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Pestañas -->
      <div style="display:flex;border-bottom:1px solid var(--border);padding:0 28px">
        <button id="tab-docs" onclick="docCambiarTab('docs')"
          style="padding:12px 20px;background:none;border:none;border-bottom:2px solid var(--accent);color:var(--accent);font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;cursor:pointer">
          MIS DOCUMENTOS
        </button>
        <button id="tab-imss" onclick="docCambiarTab('imss')"
          style="padding:12px 20px;background:none;border:none;border-bottom:2px solid transparent;color:var(--text-3);font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;cursor:pointer">
          VIGENCIA IMSS
        </button>
      </div>

      <!-- PANEL: MIS DOCUMENTOS -->
      <div id="panel-docs" style="display:flex;flex-direction:column;flex:1;overflow:hidden">
        <div style="padding:16px 28px">
          <div id="docDropZone" ondragover="docDragOver(event)" ondragleave="docDragLeave(event)" ondrop="docDrop(event)"
            style="border:2px dashed var(--border);padding:24px;text-align:center;cursor:pointer;transition:border-color 0.2s"
            onclick="document.getElementById('docFileInput').click()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:32px;height:32px;margin:0 auto 8px;display:block;color:var(--text-3)">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17,8 12,3 7,8"/><line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p style="font-family:'Barlow Condensed',sans-serif;font-size:13px;color:var(--text-2);letter-spacing:1px">
              ARRASTRA DOCUMENTOS AQUÍ O <span style="color:var(--accent)">HAZ CLIC</span>
            </p>
            <p style="font-size:11px;color:var(--text-3);margin-top:4px">INE, Acta, Pasaporte, CURP — JPG, PNG, PDF — máx. 10 MB</p>
            <input type="file" id="docFileInput" multiple accept=".jpg,.jpeg,.png,.webp,.pdf" style="display:none" onchange="docFilesSeleccionados(this.files)">
          </div>
          <div id="docColaUpload" style="display:none;margin-top:12px">
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--text-3);margin-bottom:6px">ARCHIVOS SELECCIONADOS</div>
            <div id="docColaItems"></div>
            <button onclick="subirDocumentos()" style="margin-top:8px;padding:9px 22px;background:var(--accent);color:#000;border:none;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:1px;cursor:pointer">
              ↑ SUBIR
            </button>
          </div>
          <div id="docProgreso" style="display:none;margin-top:10px;font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--accent)"></div>
        </div>
        <div style="flex:1;overflow-y:auto;padding:0 28px 28px">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--text-3);margin-bottom:10px">DOCUMENTOS SUBIDOS</div>
          <div id="docListaContratista"><div style="text-align:center;padding:30px;color:var(--text-3);font-size:13px">Cargando...</div></div>
        </div>
      </div>

      <!-- PANEL: VIGENCIA IMSS -->
      <div id="panel-imss" style="display:none;flex-direction:column;flex:1;overflow:hidden">
        <div style="padding:16px 28px">
          <div id="imssDropZone" ondragover="imssDragOver(event)" ondragleave="imssDragLeave(event)" ondrop="imssDrop(event)"
            style="border:2px dashed #3b82f6;padding:24px;text-align:center;cursor:pointer;transition:border-color 0.2s"
            onclick="document.getElementById('docImssInput').click()">
            <svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5" style="width:32px;height:32px;margin:0 auto 8px;display:block">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17,8 12,3 7,8"/><line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p style="font-family:'Barlow Condensed',sans-serif;font-size:13px;color:#3b82f6;letter-spacing:1px">
              ARRASTRA DOCUMENTO DE VIGENCIA IMSS O <span style="text-decoration:underline">HAZ CLIC</span>
            </p>
            <p style="font-size:11px;color:var(--text-3);margin-top:4px">JPG, PNG, PDF — máx. 10 MB por archivo</p>
            <input type="file" id="docImssInput" multiple accept=".jpg,.jpeg,.png,.webp,.pdf" style="display:none" onchange="docImssSeleccionado(this.files)">
          </div>
          <div id="imssColaUpload" style="display:none;margin-top:12px">
            <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--text-3);margin-bottom:6px">ARCHIVOS SELECCIONADOS</div>
            <div id="imssColaItems"></div>
            <button onclick="subirIMSS()" style="margin-top:8px;padding:9px 22px;background:#3b82f6;color:#fff;border:none;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:1px;cursor:pointer">
              ↑ SUBIR VIGENCIA IMSS
            </button>
          </div>
          <div id="imssProgreso" style="display:none;margin-top:10px;font-family:'Share Tech Mono',monospace;font-size:12px;color:#3b82f6"></div>
        </div>
        <div style="flex:1;overflow-y:auto;padding:0 28px 28px">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--text-3);margin-bottom:10px">VIGENCIAS SUBIDAS</div>
          <div id="imssListaContratista"><div style="text-align:center;padding:30px;color:var(--text-3);font-size:13px">Cargando...</div></div>
        </div>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════
       MODAL: DOCUMENTOS POR EMPRESA (Seguridad Física)
