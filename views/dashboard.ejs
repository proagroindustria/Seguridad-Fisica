  <!-- MODAL: ENROLAR PERSONA -->
  <div class="modal-facial" id="modalEnrolar">
    <div class="facial-box" style="width:580px;max-height:95vh;overflow-y:auto">
      <div class="facial-header">
        <h3>➕ Registrar Personal</h3>
        <button class="modal-close" onclick="cerrarFacialEnrolar()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px;height:18px"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="facial-body">

        <!-- PASO 1: CÁMARA -->
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--accent);margin-bottom:8px">PASO 1 — CAPTURA DE ROSTRO</div>
        <div id="enrol-status" class="facial-status">⏳ Iniciando cámara...</div>
        <div class="facial-cam-wrap">
          <video id="enrol-video" autoplay muted playsinline></video>
          <canvas id="enrol-canvas"></canvas>
        </div>
        <div id="enrol-cap-status" class="facial-status error">❌ Rostro no capturado</div>
        <div style="display:flex;justify-content:center;margin-bottom:8px">
          <button class="btn-facial" id="btn-enrol-capturar" onclick="capturarRostroEnrol()" disabled>CAPTURAR ROSTRO</button>
        </div>
        <div id="warn-foto" style="display:flex;align-items:center;gap:8px;background:#fef3c7;border:1px solid #f59e0b;padding:8px 12px;margin-bottom:12px;font-size:12px;color:#92400e">
          ⚠ Debes capturar el rostro antes de continuar
        </div>

        <!-- PASO 2: DATOS -->
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--accent);margin-bottom:8px;border-top:1px solid var(--border);padding-top:14px">PASO 2 — DATOS DEL TRABAJADOR</div>
        <div class="facial-form-grid">
          <div class="facial-field"><label>Nombre *</label><input type="text" id="enrol-nombre" placeholder="Nombre"></div>
          <div class="facial-field"><label>Apellido *</label><input type="text" id="enrol-apellido" placeholder="Apellido"></div>
          <div class="facial-field"><label>Email</label><input type="email" id="enrol-email" placeholder="correo@empresa.com"></div>
          <div class="facial-field"><label>CURP</label><input type="text" id="enrol-documento" placeholder="CURP / ID"></div>
          <div class="facial-field" style="grid-column:1/-1"><label>Empresa *</label><input type="text" id="enrol-empresa" placeholder="Nombre de la empresa contratista"></div>
          <div class="facial-field"><label>Área</label><input type="text" id="enrol-area" placeholder="Área"></div>
          <div class="facial-field"><label>Cargo</label><input type="text" id="enrol-cargo" placeholder="Cargo"></div>
        </div>

        <!-- PASO 3: DOCUMENTOS -->
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;color:var(--accent);margin-bottom:8px;border-top:1px solid var(--border);padding-top:14px">PASO 3 — DOCUMENTOS OBLIGATORIOS</div>

        <!-- Credencial -->
        <div style="margin-bottom:4px">
          <div style="font-size:11px;color:var(--text-3);margin-bottom:6px;font-family:'Barlow Condensed',sans-serif;letter-spacing:0.5px">
            CREDENCIAL (INE / PASAPORTE) <span style="color:var(--danger)">*</span>
          </div>
          <div id="enrol-cred-drop" onclick="if(!enrolCredProcesado)document.getElementById('enrol-cred-input').click()"
            style="border:2px dashed var(--border);padding:16px;text-align:center;cursor:pointer;transition:all 0.2s"
            ondragover="event.preventDefault();this.style.borderColor='var(--accent)'"
            ondragleave="this.style.borderColor='var(--border)'"
            ondrop="enrolDropFile(event,'cred')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:24px;height:24px;margin:0 auto 4px;display:block;color:var(--text-3)">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17,8 12,3 7,8"/><line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <span id="enrol-cred-label" style="font-size:12px;color:var(--text-3)">Arrastra o haz clic para subir credencial</span>
            <input type="file" id="enrol-cred-input" accept=".jpg,.jpeg,.png,.webp,.pdf" style="display:none" onchange="enrolArchivoSeleccionado(this,'cred')">
          </div>
          <div id="enrol-cred-proceso" style="display:none;margin-top:6px;padding:10px 14px;border:1px solid var(--border);font-family:'Share Tech Mono',monospace;font-size:12px"></div>
          <button id="enrol-cred-retry" onclick="enrolReintentarDoc('cred')" style="display:none;margin-top:6px;padding:6px 14px;background:transparent;border:1px solid var(--warning);color:var(--warning);font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:1px;cursor:pointer">↺ REINTENTAR CREDENCIAL</button>
        </div>
        <div id="warn-cred" style="display:flex;align-items:center;gap:8px;background:#fef3c7;border:1px solid #f59e0b;padding:8px 12px;margin-bottom:8px;font-size:12px;color:#92400e">
          ⚠ La credencial es obligatoria
        </div>

        <!-- Vigencia IMSS -->
        <div style="margin-bottom:4px">
          <div style="font-size:11px;color:var(--text-3);margin-bottom:6px;font-family:'Barlow Condensed',sans-serif;letter-spacing:0.5px">
            VIGENCIA IMSS <span style="color:var(--danger)">*</span>
          </div>
          <div id="enrol-imss-drop" onclick="if(!enrolImssProcesado)document.getElementById('enrol-imss-input').click()"
            style="border:2px dashed #3b82f6;padding:16px;text-align:center;cursor:pointer;transition:all 0.2s"
            ondragover="event.preventDefault();this.style.borderColor='#60a5fa'"
            ondragleave="this.style.borderColor='#3b82f6'"
            ondrop="enrolDropFile(event,'imss')">
            <svg viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5" style="width:24px;height:24px;margin:0 auto 4px;display:block">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17,8 12,3 7,8"/><line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <span id="enrol-imss-label" style="font-size:12px;color:#3b82f6">Arrastra o haz clic para subir vigencia IMSS</span>
            <input type="file" id="enrol-imss-input" accept=".jpg,.jpeg,.png,.webp,.pdf" style="display:none" onchange="enrolArchivoSeleccionado(this,'imss')">
          </div>
          <div id="enrol-imss-proceso" style="display:none;margin-top:6px;padding:10px 14px;border:1px solid var(--border);font-family:'Share Tech Mono',monospace;font-size:12px"></div>
          <button id="enrol-imss-retry" onclick="enrolReintentarDoc('imss')" style="display:none;margin-top:6px;padding:6px 14px;background:transparent;border:1px solid var(--warning);color:var(--warning);font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:1px;cursor:pointer">↺ REINTENTAR VIGENCIA IMSS</button>
        </div>
        <div id="warn-imss" style="display:flex;align-items:center;gap:8px;background:#fef3c7;border:1px solid #f59e0b;padding:8px 12px;margin-bottom:8px;font-size:12px;color:#92400e">
          ⚠ La vigencia IMSS es obligatoria
        </div>

        <!-- Estado de guardado -->
        <div id="enrol-save-status" style="display:none;margin-bottom:12px;font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--accent);text-align:center"></div>

        <div style="display:flex;gap:10px;justify-content:center">
          <div id="enrol-pendiente-id" style="display:none"></div>
          <button class="btn-aprobar" id="btn-enrol-guardar" onclick="guardarEnrolamiento()" disabled>REGISTRAR PERSONAL</button>
          <button class="btn-secondary" onclick="cerrarFacialEnrolar()">Cancelar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL: HISTORIAL DE ACCESOS -->
  <div class="modal-facial" id="modalHistorial">
